---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import TeamsHero from '../components/TeamsHero.astro';
import TeamsProblem from '../components/TeamsProblem.astro';
import TeamsSolution from '../components/TeamsSolution.astro';
import TeamsSteps from '../components/TeamsSteps.astro';
import TeamsDifferent from '../components/TeamsDifferent.astro';
import TeamsNutrition from '../components/TeamsNutrition.astro';
import TeamsServes from '../components/TeamsServes.astro';
import TeamsSuccess from '../components/TeamsSuccess.astro';
import FAQ from '../components/FAQ.astro';
import TeamsBottomCTA from '../components/TeamsBottomCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Nimbus Healthcare - Teams">
  <Navbar />
  <main>
    <TeamsHero />

    <!-- Trust Bar — mobile only, below hero -->
    <section class="md:hidden bg-cream px-[10px] pt-[10px] pb-0">
      <div class="border border-dark/15 rounded-2xl p-5 flex flex-col items-start gap-4">
        <div class="flex items-center gap-2 text-dark">
          <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 18 18" fill="none"><path d="M2 14V8h3v6H2zm5.5 0V4h3v10h-3zM13 14V1h3v13h-3z" fill="currentColor"/></svg>
          <span class="font-inter font-medium text-sm text-dark">94% patient success rate</span>
        </div>
        <div class="flex items-center gap-2 text-dark">
          <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 18 18" fill="none"><path d="M9 1L2 4v5c0 4.14 2.98 8.02 7 9 4.02-.98 7-4.86 7-9V4L9 1zm0 2.04l5 2.14v3.82c0 3.31-2.38 6.41-5 7.18-2.62-.77-5-3.87-5-7.18V5.18l5-2.14z" fill="currentColor"/></svg>
          <span class="font-inter font-medium text-sm text-dark">Licensed physicians</span>
        </div>
        <div class="flex items-center gap-2 text-dark">
          <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 18 18" fill="none"><path d="M16.5 1h-6.79a1.5 1.5 0 00-1.06.44L1.44 8.65a1.5 1.5 0 000 2.12l5.79 5.79a1.5 1.5 0 002.12 0l7.21-7.21A1.5 1.5 0 0017 8.29V2.5A1.5 1.5 0 0016.5 1zM13.5 6a1.5 1.5 0 110-3 1.5 1.5 0 010 3z" fill="currentColor"/></svg>
          <span class="font-inter font-medium text-sm text-dark">Flat-rate pricing</span>
        </div>
        <div class="flex items-center gap-2 text-dark">
          <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 18 18" fill="none"><path d="M9 16.35l-1.45-1.32C3.4 11.36 1 9.28 1 6.5 1 4.42 2.42 3 4.5 3c1.74 0 3.41 1.01 4.5 2.09C10.09 4.01 11.76 3 13.5 3 15.58 3 17 4.42 17 6.5c0 2.78-2.4 4.86-6.55 8.54L9 16.35z" fill="currentColor"/></svg>
          <span class="font-inter font-medium text-sm text-dark">Ongoing clinical support</span>
        </div>
        <div class="flex items-center gap-2 text-dark">
          <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 18 18" fill="none"><path d="M11 1H7v4H3v4h4v4h4V9h4V5h-4V1z" fill="currentColor"/></svg>
          <span class="font-inter font-medium text-sm text-dark">Our own pharmacy</span>
        </div>
      </div>
    </section>

    <TeamsProblem />
    <TeamsSolution />
    <TeamsSteps />
    <TeamsDifferent />
    <TeamsNutrition />
    <TeamsServes />
    <TeamsSuccess />
    <FAQ />
  </main>
  <div class="bg-cream px-[10px] pb-[10px]">
    <div class="bg-[#EAE4DD] rounded-[14px]">
      <TeamsBottomCTA />
      <Footer />
    </div>
  </div>
</Layout>
