    border-color: rgba(245, 240, 234, 0.4);
    background: rgba(245, 240, 234, 0.05);
  }
  .state-btn.selected {
    border-color: #2A9D8F;
    background: rgba(42, 157, 143, 0.1);
    color: #2A9D8F;
  }
