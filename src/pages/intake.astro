---
import Layout from '../layouts/Layout.astro';
import logoWhite from '../assets/NB_br_Logo White/NB_br_Logo White_0325.png';
import logoBlack from '../assets/NB_br_Logo Black/NB_br_Logo Black_0325.png';
---

<Layout title="Nimbus Healthcare - Intake">
  <main>
    <section class="bg-[#1A1816] h-screen flex flex-col overflow-hidden" id="intake-app">
      <!-- Progress Bar -->
      <div class="w-full h-[3px] bg-cream/5 intake-progress-track shrink-0">
        <div class="h-full bg-teal transition-all duration-500 ease-out" id="progress-bar" style="width: 5.56%"></div>
      </div>

      <!-- Sticky Top Bar -->
      <div class="px-6 shrink-0 intake-sticky-header">
        <div class="max-w-[620px] mx-auto relative flex items-center justify-between py-5">
          <!-- Left: Back -->
          <div class="flex items-center gap-3">
            <button
              id="intake-back"
              class="w-10 h-10 rounded-full border border-cream/15 flex items-center justify-center text-cream/50 hover:text-cream hover:border-cream/30 transition-colors cursor-pointer intake-back-btn"
              aria-label="Go back"
            >
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <span class="font-montserrat text-cream/50 text-xs font-semibold tracking-[0.15em] uppercase intake-muted" id="intake-phase">Back</span>
          </div>
          <!-- Center: Logo -->
          <div class="absolute left-1/2 -translate-x-1/2">
            <img src={logoWhite.src} alt="Nimbus Healthcare" class="h-[30px]" id="logo-white" />
            <img src={logoBlack.src} alt="Nimbus Healthcare" class="h-[30px] hidden" id="logo-black" />
          </div>
          <!-- Right: Counter + Theme -->
          <div class="flex items-center gap-4">
            <span class="font-inter text-cream/40 text-sm intake-muted" id="intake-counter">6%</span>
            <button
              id="theme-toggle"
              class="w-10 h-10 rounded-full border border-cream/15 flex items-center justify-center text-cream/50 hover:text-cream hover:border-cream/30 transition-colors cursor-pointer intake-back-btn"
              aria-label="Toggle light mode"
            >
              <svg id="icon-sun" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="3.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M9 2v1.5M9 14.5V16M2 9h1.5M14.5 9H16M4.05 4.05l1.06 1.06M12.89 12.89l1.06 1.06M4.05 13.95l1.06-1.06M12.89 5.11l1.06-1.06" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              <svg id="icon-moon" width="18" height="18" viewBox="0 0 18 18" fill="none" class="hidden">
                <path d="M15.36 10.68A6.5 6.5 0 017.32 2.64a7.5 7.5 0 108.04 8.04z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Scrollable Content -->
      <div class="flex-1 overflow-y-auto px-6 pb-8" id="intake-content">
        <div class="max-w-[620px] mx-auto">

          <!-- ========== STEP 1: State Selection ========== -->

          <!-- Step 1: Active -->
          <div id="step-1-active" class="mt-4">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label">Qualify</p>
            <h1 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading">
              Hi, I'm Nimy — your health coach from Nimbus Healthcare
            </h1>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-5 intake-body">
              I'm powered by IntelliHealth™, Nimbus Healthcare's clinical intelligence. Everything we discuss is reviewed by a licensed clinician before any next steps.
            </p>
            <p class="font-inter text-cream font-semibold text-base intake-bold">
              First up — which state are you based in?
            </p>

            <div class="grid grid-cols-3 gap-3 mt-8" id="state-grid">
              <button class="state-btn">Alabama</button>
              <button class="state-btn">Arizona</button>
              <button class="state-btn">Arkansas</button>
              <button class="state-btn">Colorado</button>
              <button class="state-btn">Florida</button>
              <button class="state-btn">Georgia</button>
              <button class="state-btn">Hawaii</button>
              <button class="state-btn">Idaho</button>
              <button class="state-btn">Illinois</button>
              <button class="state-btn">Indiana</button>
              <button class="state-btn">Iowa</button>
              <button class="state-btn">Kansas</button>
              <button class="state-btn">Louisiana</button>
              <button class="state-btn">Maine</button>
              <button class="state-btn">Maryland</button>
              <button class="state-btn">Michigan</button>
              <button class="state-btn">Missouri</button>
              <button class="state-btn">Montana</button>
              <button class="state-btn">Nebraska</button>
              <button class="state-btn">New Jersey</button>
              <button class="state-btn">New York</button>
              <button class="state-btn">North Dakota</button>
              <button class="state-btn">Ohio</button>
              <button class="state-btn">Oklahoma</button>
              <button class="state-btn">South Dakota</button>
              <button class="state-btn">Tennessee</button>
              <button class="state-btn">Texas</button>
              <button class="state-btn">Washington</button>
              <button class="state-btn">Wisconsin</button>
              <button class="state-btn">Wyoming</button>
            </div>

            <p id="state-not-listed" class="font-inter text-cream/30 text-sm text-center mt-6 cursor-pointer hover:text-cream/50 transition-colors intake-subtle">
              State not on the list?
            </p>

            <!-- Not-served state message -->
            <div id="state-not-msg" class="hidden mt-4 rounded-2xl border border-cream/10 bg-cream/[0.03] px-5 py-5">
              <p class="font-inter text-cream/70 text-base leading-[1.7] intake-body">
                We're expanding! We don't serve your state yet, but we're working on it. Check back soon or reach us at <a href="mailto:support@nimbushealthcare.com" class="text-teal hover:underline">support@nimbushealthcare.com</a>
              </p>
            </div>
          </div>

          <!-- Step 1: Collapsed -->
          <div id="step-1-collapsed" class="hidden">
            <div class="flex items-center justify-between py-2">
              <div>
                <p class="font-montserrat text-teal text-[10px] font-semibold tracking-[0.15em] uppercase mb-1 intake-label">Getting to know you</p>
                <p class="font-inter text-cream/50 text-sm intake-body">Hi, I'm Nimy — your health coach from Nimbus Healthcare</p>
              </div>
              <button class="edit-step-btn flex items-center gap-2 border border-cream/15 rounded-full px-4 py-2 text-cream text-sm font-inter font-medium hover:border-cream/30 transition-colors cursor-pointer intake-back-btn intake-heading" data-edit-step="1">
                <span id="step-1-answer">Texas</span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M10.08 1.92a1.5 1.5 0 012.12 0l.38.38a1.5 1.5 0 010 2.12L5.5 11.5 2 12.5l1-3.5 7.08-7.08z" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <div class="border-t border-cream/10 mt-4 intake-border"></div>
          </div>

          <!-- ========== STEP 2: Date of Birth + Sex ========== -->
          <div id="step-2-active" class="hidden mt-8">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label">Getting to know you</p>
            <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading">
              Great! Let's start here
            </h2>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-10 intake-body">
              Tell me your origin story, the short version.
            </p>

            <!-- Date of Birth -->
            <div class="mb-8">
              <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Date of Birth</label>
              <input
                type="text"
                id="dob-input"
                placeholder="MM/DD/YYYY"
                maxlength="10"
                class="w-full bg-transparent border border-cream/15 rounded-2xl px-5 py-4 font-inter text-cream text-base placeholder:text-cream/25 focus:outline-none focus:border-cream/40 transition-colors intake-input"
              />
            </div>

            <!-- Sex at Birth -->
            <div class="mb-8">
              <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Sex at Birth</label>
              <div class="grid grid-cols-2 gap-4">
                <button class="sex-btn font-inter text-cream text-base font-medium border border-cream/15 rounded-2xl py-4 hover:border-cream/30 transition-colors cursor-pointer intake-heading" data-value="Male">Male</button>
                <button class="sex-btn font-inter text-cream text-base font-medium border border-cream/15 rounded-2xl py-4 hover:border-cream/30 transition-colors cursor-pointer intake-heading" data-value="Female">Female</button>
              </div>
            </div>
          </div>

          <!-- Step 2: Collapsed -->
          <div id="step-2-collapsed" class="hidden">
            <div class="flex items-center justify-between py-2">
              <div>
                <p class="font-montserrat text-teal text-[10px] font-semibold tracking-[0.15em] uppercase mb-1 intake-label">Getting to know you</p>
                <p class="font-inter text-cream/50 text-sm intake-body">Great! Let's start here</p>
              </div>
              <button class="edit-step-btn flex items-center gap-2 border border-cream/15 rounded-full px-4 py-2 text-cream text-sm font-inter font-medium hover:border-cream/30 transition-colors cursor-pointer intake-back-btn intake-heading" data-edit-step="2">
                <span id="step-2-answer">01/01/1990 · male</span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M10.08 1.92a1.5 1.5 0 012.12 0l.38.38a1.5 1.5 0 010 2.12L5.5 11.5 2 12.5l1-3.5 7.08-7.08z" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <div class="border-t border-cream/10 mt-4 intake-border"></div>
          </div>

          <!-- ========== STEP 3: Height + Weight ========== -->
          <div id="step-3-active" class="hidden mt-8">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label">Getting to know you</p>
            <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading">
              Now, a little more about you
            </h2>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-10 intake-body">
              These details just help me personalize your care plan.
            </p>

            <!-- Height -->
            <div class="mb-8">
              <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Height</label>
              <div class="flex gap-4">
                <!-- Feet -->
                <div class="flex-1 flex items-center border border-cream/15 rounded-2xl overflow-hidden stepper-box">
                  <button class="stepper-btn w-14 h-full flex items-center justify-center text-cream/40 hover:text-cream transition-colors cursor-pointer intake-muted" data-target="height-ft" data-dir="-1">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                  <div class="flex-1 flex items-center justify-center gap-2 py-4">
                    <span class="font-inter text-cream text-2xl font-semibold intake-heading" id="height-ft">5</span>
                    <span class="font-inter text-cream/40 text-sm intake-muted">ft</span>
                  </div>
                  <button class="stepper-btn w-14 h-full flex items-center justify-center text-cream/40 hover:text-cream transition-colors cursor-pointer intake-muted" data-target="height-ft" data-dir="1">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 4v10M4 9h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                </div>
                <!-- Inches -->
                <div class="flex-1 flex items-center border border-cream/15 rounded-2xl overflow-hidden stepper-box">
                  <button class="stepper-btn w-14 h-full flex items-center justify-center text-cream/40 hover:text-cream transition-colors cursor-pointer intake-muted" data-target="height-in" data-dir="-1">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                  <div class="flex-1 flex items-center justify-center gap-2 py-4">
                    <span class="font-inter text-cream text-2xl font-semibold intake-heading" id="height-in">6</span>
                    <span class="font-inter text-cream/40 text-sm intake-muted">in</span>
                  </div>
                  <button class="stepper-btn w-14 h-full flex items-center justify-center text-cream/40 hover:text-cream transition-colors cursor-pointer intake-muted" data-target="height-in" data-dir="1">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 4v10M4 9h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                </div>
              </div>
            </div>

            <!-- Weight -->
            <div class="mb-8">
              <label class="font-inter text-cream font-semibold text-base block mb-3 intake-bold">Weight (lbs)</label>
              <div class="flex items-center border border-cream/15 rounded-2xl overflow-hidden stepper-box">
                <button class="stepper-btn w-16 h-full flex items-center justify-center text-cream/40 hover:text-cream transition-colors cursor-pointer intake-muted" data-target="weight-lbs" data-dir="-1">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
                <div class="flex-1 flex items-center justify-center gap-2 py-4">
                  <span class="font-inter text-cream text-2xl font-semibold intake-heading" id="weight-lbs">150</span>
                  <span class="font-inter text-cream/40 text-sm intake-muted">lbs</span>
                </div>
                <button class="stepper-btn w-16 h-full flex items-center justify-center text-cream/40 hover:text-cream transition-colors cursor-pointer intake-muted" data-target="weight-lbs" data-dir="1">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 4v10M4 9h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
              </div>
            </div>

            <!-- Continue button -->
            <button
              id="step-3-continue"
              class="w-full bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-base rounded-full px-10 py-4 transition-colors cursor-pointer mt-4"
            >
              Continue
            </button>
          </div>

          <!-- Step 3: Collapsed -->
          <div id="step-3-collapsed" class="hidden">
            <div class="flex items-center justify-between py-2">
              <div>
                <p class="font-montserrat text-teal text-[10px] font-semibold tracking-[0.15em] uppercase mb-1 intake-label">Getting to know you</p>
                <p class="font-inter text-cream/50 text-sm intake-body">Now, a little more about you</p>
              </div>
              <button class="edit-step-btn flex items-center gap-2 border border-cream/15 rounded-full px-4 py-2 text-cream text-sm font-inter font-medium hover:border-cream/30 transition-colors cursor-pointer intake-back-btn intake-heading" data-edit-step="3">
                <span id="step-3-answer">5'6" · 150 lbs</span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M10.08 1.92a1.5 1.5 0 012.12 0l.38.38a1.5 1.5 0 010 2.12L5.5 11.5 2 12.5l1-3.5 7.08-7.08z" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <div class="border-t border-cream/10 mt-4 intake-border"></div>
          </div>

          <!-- ========== STEP 4: Your Goals ========== -->
          <div id="step-4-active" class="hidden mt-8">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label">Your Goals</p>
            <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading">
              So, now tell me what brought you here today?
            </h2>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-10 intake-body">
              Pick all that apply so I can keep building a plan personalized to you.
            </p>

            <div class="grid grid-cols-2 gap-4" id="goals-grid">
              <button class="goal-btn" data-value="Lose weight">
                <span class="font-inter text-cream text-base font-medium intake-heading">Lose weight</span>
              </button>
              <button class="goal-btn" data-value="Feel more energy">
                <span class="font-inter text-cream text-base font-medium intake-heading">Feel more energy</span>
              </button>
              <button class="goal-btn" data-value="Improve health markers">
                <span class="font-inter text-cream text-base font-medium intake-heading">Improve health markers</span>
              </button>
              <button class="goal-btn" data-value="Build confidence">
                <span class="font-inter text-cream text-base font-medium intake-heading">Build confidence</span>
              </button>
              <button class="goal-btn" data-value="Better mobility">
                <span class="font-inter text-cream text-base font-medium intake-heading">Better mobility</span>
              </button>
              <button class="goal-btn" data-value="Sleep better">
                <span class="font-inter text-cream text-base font-medium intake-heading">Sleep better</span>
              </button>
            </div>

            <!-- Continue button (appears after selection) -->
            <button
              id="step-4-continue"
              class="w-full bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-base rounded-full px-10 py-4 transition-colors cursor-pointer mt-8 hidden"
            >
              Continue
            </button>
          </div>

          <!-- Step 4: Collapsed -->
          <div id="step-4-collapsed" class="hidden">
            <div class="flex items-center justify-between py-2">
              <div>
                <p class="font-montserrat text-teal text-[10px] font-semibold tracking-[0.15em] uppercase mb-1 intake-label">Your Goals</p>
                <p class="font-inter text-cream/50 text-sm intake-body">What brought you here today</p>
              </div>
              <button class="edit-step-btn flex items-center gap-2 border border-cream/15 rounded-full px-4 py-2 text-cream text-sm font-inter font-medium hover:border-cream/30 transition-colors cursor-pointer intake-back-btn intake-heading" data-edit-step="4">
                <span id="step-4-answer">Lose weight</span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M10.08 1.92a1.5 1.5 0 012.12 0l.38.38a1.5 1.5 0 010 2.12L5.5 11.5 2 12.5l1-3.5 7.08-7.08z" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <div class="border-t border-cream/10 mt-4 intake-border"></div>
          </div>

          <!-- ========== STEP 5: GLP-1 Experience ========== -->
          <div id="step-5-active" class="hidden mt-8">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label">Building Your Plan</p>
            <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading">
              Have you tried a GLP-1 before?
            </h2>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-10 intake-body">
              This just helps me understand where you are in your journey.
            </p>

            <div class="flex flex-col gap-4" id="glp1-options">
              <button class="option-btn" data-value="Yes, I'm currently on one">Yes, I'm currently on one</button>
              <button class="option-btn" data-value="Yes, but I stopped">Yes, but I stopped</button>
              <button class="option-btn" data-value="No, this would be my first time">No, this would be my first time</button>
              <button class="option-btn" data-value="Honestly, I'm not sure">Honestly, I'm not sure</button>
            </div>
          </div>

          <!-- Step 5: Collapsed -->
          <div id="step-5-collapsed" class="hidden">
            <div class="flex items-center justify-between py-2">
              <div>
                <p class="font-montserrat text-teal text-[10px] font-semibold tracking-[0.15em] uppercase mb-1 intake-label">Building Your Plan</p>
                <p class="font-inter text-cream/50 text-sm intake-body">Have you tried a GLP-1 before?</p>
              </div>
              <button class="edit-step-btn flex items-center gap-2 border border-cream/15 rounded-full px-4 py-2 text-cream text-sm font-inter font-medium hover:border-cream/30 transition-colors cursor-pointer intake-back-btn intake-heading" data-edit-step="5">
                <span id="step-5-answer">—</span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M10.08 1.92a1.5 1.5 0 012.12 0l.38.38a1.5 1.5 0 010 2.12L5.5 11.5 2 12.5l1-3.5 7.08-7.08z" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <div class="border-t border-cream/10 mt-4 intake-border"></div>
          </div>

          <!-- ========== STEP 6: Account Setup ========== -->
          <div id="step-6-active" class="hidden mt-8">
            <p class="font-montserrat text-teal text-xs font-semibold tracking-[0.15em] uppercase mb-2 intake-label">Building Your Plan</p>
            <h2 class="font-fraunces text-cream text-[clamp(28px,4vw,40px)] leading-[1.15] tracking-[-0.02em] mb-4 intake-heading">
              Let's set up your account
            </h2>
            <p class="font-inter text-cream/50 text-base leading-[1.6] mb-10 intake-body">
              Just a quick step so I can save your progress and show you your options.
            </p>

            <!-- Email input -->
            <label class="block mb-2">
              <span class="font-inter text-cream font-semibold text-base intake-bold">Email address</span>
            </label>
            <input
              type="email"
              id="account-email"
              placeholder="you@example.com"
              class="account-input mb-6 intake-heading"
            />

            <!-- Password input -->
            <label class="block mb-2">
              <span class="font-inter text-cream font-semibold text-base intake-bold">Create a password</span>
            </label>
            <input
              type="password"
              id="account-password"
              placeholder="At least 8 characters"
              class="account-input mb-8 intake-heading"
            />

            <!-- Continue button -->
            <button
              id="step-6-continue"
              class="w-full bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-base rounded-full px-10 py-4 transition-colors cursor-pointer mb-6"
            >
              Continue
            </button>

            <!-- Divider -->
            <div class="flex items-center gap-4 mb-6">
              <div class="flex-1 h-px bg-cream/10 intake-border-bg"></div>
              <span class="font-inter text-cream/30 text-sm intake-muted">or</span>
              <div class="flex-1 h-px bg-cream/10 intake-border-bg"></div>
            </div>

            <!-- Social buttons -->
