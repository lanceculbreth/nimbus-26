    background: rgba(42, 157, 143, 0.08);
    color: #2A9D8F;
  }
  .light-mode .sex-btn {
    color: #1A1816;
    border-color: rgba(26, 24, 22, 0.15);
  }
  .light-mode .sex-btn:hover {
    border-color: rgba(26, 24, 22, 0.35);
  }
  .light-mode .sex-btn.selected {
    border-color: #2A9D8F;
    background: rgba(42, 157, 143, 0.08);
    color: #2A9D8F;
  }
  .light-mode .intake-input {
    color: #1A1816;
    border-color: rgba(26, 24, 22, 0.15);
  }
  .light-mode .intake-input::placeholder {
    color: rgba(26, 24, 22, 0.25);
  }
  .light-mode .intake-input:focus {
    border-color: rgba(26, 24, 22, 0.35);
  }
  .goal-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 28px 16px;
    border: 1px solid rgba(245, 240, 234, 0.15);
    border-radius: 16px;
    background: transparent;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .goal-btn:hover {
    border-color: rgba(245, 240, 234, 0.35);
    background: rgba(245, 240, 234, 0.03);
  }
  .goal-icon {
    color: rgba(245, 240, 234, 0.5);
    margin-bottom: 12px;
    transition: color 0.15s ease;
  }
  .goal-btn:hover .goal-icon {
    color: rgba(245, 240, 234, 0.7);
  }
  .goal-btn.selected {
    border-color: #2A9D8F;
    background: rgba(42, 157, 143, 0.1);
  }
  .goal-btn.selected .goal-icon {
    color: #2A9D8F;
  }
  .light-mode .goal-btn {
    border-color: rgba(26, 24, 22, 0.15);
  }
  .light-mode .goal-btn:hover {
    border-color: rgba(26, 24, 22, 0.35);
    background: rgba(26, 24, 22, 0.03);
  }
  .light-mode .goal-btn.selected {
    border-color: #2A9D8F;
    background: rgba(42, 157, 143, 0.08);
  }
  .light-mode .goal-icon {
    color: rgba(26, 24, 22, 0.4);
  }
  .light-mode .goal-btn:hover .goal-icon {
    color: rgba(26, 24, 22, 0.6);
  }
  .light-mode .goal-btn.selected .goal-icon {
    color: #2A9D8F;
  }
  .option-btn {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #F5F0EA;
    border: 1px solid rgba(245, 240, 234, 0.15);
    border-radius: 16px;
    padding: 20px 24px;
    background: transparent;
    cursor: pointer;
    transition: all 0.15s ease;
    text-align: left;
  }
  .option-btn:hover {
    border-color: rgba(245, 240, 234, 0.35);
    background: rgba(245, 240, 234, 0.03);
  }
  .option-btn.selected {
    border-color: #2A9D8F;
    background: rgba(42, 157, 143, 0.1);
    color: #2A9D8F;
  }
  .light-mode .option-btn {
    color: #1A1816;
    border-color: rgba(26, 24, 22, 0.15);
  }
  .light-mode .option-btn:hover {
    border-color: rgba(26, 24, 22, 0.35);
    background: rgba(26, 24, 22, 0.03);
  }
  .light-mode .option-btn.selected {
    border-color: #2A9D8F;
    background: rgba(42, 157, 143, 0.08);
    color: #2A9D8F;
  }

  /* Account setup step */
  .account-input {
    width: 100%;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #F5F0EA;
    background: transparent;
    border: 1px solid rgba(245, 240, 234, 0.15);
    border-radius: 14px;
    padding: 20px 24px;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .account-input::placeholder {
    color: rgba(245, 240, 234, 0.25);
  }
  .account-input:focus {
    border-color: rgba(245, 240, 234, 0.35);
  }
  .account-social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    width: 100%;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #F5F0EA;
    background: transparent;
    border: 1px solid rgba(245, 240, 234, 0.15);
    border-radius: 9999px;
    padding: 18px 24px;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .account-social-btn:hover {
    border-color: rgba(245, 240, 234, 0.35);
    background: rgba(245, 240, 234, 0.04);
  }
  .light-mode .account-input {
    color: #1A1816;
    border-color: rgba(26, 24, 22, 0.15);
  }
  .light-mode .account-input::placeholder {
    color: rgba(26, 24, 22, 0.3);
  }
  .light-mode .account-input:focus {
    border-color: rgba(26, 24, 22, 0.35);
  }
  .light-mode .account-social-btn {
    color: #1A1816;
    border-color: rgba(26, 24, 22, 0.15);
  }
  .light-mode .account-social-btn:hover {
    border-color: rgba(26, 24, 22, 0.35);
    background: rgba(26, 24, 22, 0.04);
  }

  /* ===== Step 7: Plan / Pricing ===== */
  .plan-med-card {
    position: relative;
    border: 1px solid rgba(245, 240, 234, 0.12);
    border-radius: 20px;
    padding: 20px;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease;
    background: transparent;
  }
  .plan-med-card:hover {
    border-color: rgba(245, 240, 234, 0.25);
  }
  .plan-med-card.selected {
    border-color: #2A9D8F;
    background: rgba(42, 157, 143, 0.06);
  }
  .plan-card-badge {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #2A9D8F;
    margin-bottom: 14px;
  }
  .plan-card-badge.alt {
    color: rgba(245, 240, 234, 0.4);
  }
  .commit-btn {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    padding: 18px 8px;
    border: 1px solid rgba(245, 240, 234, 0.12);
    border-radius: 14px;
    background: transparent;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease;
    overflow: hidden;
    min-height: 72px;
  }
  .commit-btn--popular {
    padding-top: 26px;
  }
  .commit-btn:hover {
    border-color: rgba(245, 240, 234, 0.25);
  }
  .commit-btn.selected {
    border-color: #2A9D8F;
    background: rgba(42, 157, 143, 0.06);
  }
  .commit-label {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #F5F0EA;
  }
  .commit-save {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: rgba(245, 240, 234, 0.45);
  }
  .commit-popular {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    font-family: 'Montserrat', sans-serif;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: center;
    padding: 5px 0;
    background: rgba(42, 157, 143, 0.15);
    color: rgba(42, 157, 143, 0.6);
  }
  .commit-btn.selected .commit-popular {
    background: rgba(42, 157, 143, 0.25);
    color: #2A9D8F;
  }
  .plan-included-box {
    border: 1px solid rgba(245, 240, 234, 0.12);
    border-radius: 16px;
    padding: 20px;
  }
  .plan-summary-box {
    border: 1px solid rgba(245, 240, 234, 0.12);
    border-radius: 16px;
    padding: 20px;
  }
  .light-mode .plan-med-card {
    border-color: rgba(26, 24, 22, 0.12);
  }
  .light-mode .plan-med-card.selected {
    border-color: #2A9D8F;
    background: rgba(42, 157, 143, 0.06);
  }
  .light-mode .commit-btn {
    border-color: rgba(26, 24, 22, 0.12);
  }
  .light-mode .commit-btn.selected {
    border-color: #2A9D8F;
    background: rgba(42, 157, 143, 0.06);
  }
  .light-mode .commit-label {
    color: #1A1816;
  }
  .light-mode .plan-included-box,
  .light-mode .plan-summary-box {
    border-color: rgba(26, 24, 22, 0.12);
  }

  .stepper-box {
    background: transparent;
  }
  .stepper-btn {
    background: transparent;
    border: none;
    padding: 0;
  }
  .light-mode .stepper-box {
    border-color: rgba(26, 24, 22, 0.15);
  }
  .light-mode .stepper-btn {
    color: rgba(26, 24, 22, 0.35);
  }
  .light-mode .stepper-btn:hover {
    color: #1A1816;
  }
  .light-mode .intake-subtle {
    color: rgba(26, 24, 22, 0.25);
  }
  .light-mode .intake-subtle:hover {
    color: rgba(26, 24, 22, 0.5);
  }
  .light-mode .exit-modal-box {
    background: #F5F0EA;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }
  .light-mode .exit-modal-heading {
    color: #1A1816;
  }
  .light-mode .exit-modal-body {
    color: rgba(26, 24, 22, 0.55);
  }
  .light-mode .exit-modal-btn {
    border-color: rgba(26, 24, 22, 0.15);
    color: #1A1816;
  }
  .light-mode .exit-modal-btn:hover {
    border-color: rgba(26, 24, 22, 0.3);
  }
  .light-mode .intake-progress-track {
    background: rgba(26, 24, 22, 0.06);
  }
  .light-mode .intake-badge {
    color: rgba(26, 24, 22, 0.3);
  }
  .light-mode .intake-border {
    border-color: rgba(26, 24, 22, 0.08);
  }

  /* ── Checkout Step (Step 8) ── */
  .co-summary-box {
    background: rgba(245, 240, 234, 0.04);
    border: 1px solid rgba(245, 240, 234, 0.1);
    border-radius: 14px;
    padding: 16px 18px;
  }
  .co-express-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 16px 24px;
    border-radius: 12px;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s ease;
    border: none;
  }
  .co-express-btn:hover { opacity: 0.88; }
  .co-express-btn--apple { background: #000; color: #fff; }
  .co-express-btn--google { background: #fff; color: #1a1a1a; }
  .co-express-btn--shop { background: #5433EB; color: #fff; }
  .co-label {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: rgba(245, 240, 234, 0.5);
    margin-bottom: 6px;
  }
  .co-input {
    width: 100%;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    color: #F5F0EA;
    background: rgba(245, 240, 234, 0.05);
    border: 1px solid rgba(245, 240, 234, 0.12);
    border-radius: 12px;
    padding: 14px 16px;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .co-input::placeholder { color: rgba(245, 240, 234, 0.2); }
  .co-input:focus { border-color: rgba(245, 240, 234, 0.3); }
  .co-input--icon {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
  }
  .co-input-bare {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    color: #F5F0EA;
    min-width: 0;
  }
  .co-input-bare::placeholder { color: rgba(245, 240, 234, 0.2); }

  /* ── Comorbidity Checkboxes (Step 10) ── */
  .comorbidity-card {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    border: 1px solid rgba(245, 240, 234, 0.12);
    border-radius: 14px;
    padding: 18px 20px;
    background: rgba(245, 240, 234, 0.02);
    cursor: pointer;
    transition: all 0.15s ease;
    text-align: left;
  }
  .comorbidity-card:hover {
    border-color: rgba(245, 240, 234, 0.25);
    background: rgba(245, 240, 234, 0.04);
  }
  .comorbidity-card.selected {
    border-color: rgba(42, 157, 143, 0.5);
    background: rgba(42, 157, 143, 0.06);
  }
  .comorbidity-checkbox {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    border: 1.5px solid rgba(245, 240, 234, 0.25);
    background: transparent;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s ease;
  }
  .comorbidity-card.selected .comorbidity-checkbox {
    background: #2A9D8F;
    border-color: #2A9D8F;
  }
  .comorbidity-check-icon {
    display: none;
  }
  .comorbidity-card.selected .comorbidity-check-icon {
    display: block;
  }
  /* Light mode */
  .light-mode .comorbidity-card {
    border-color: rgba(26, 24, 22, 0.12);
    background: rgba(26, 24, 22, 0.02);
  }
  .light-mode .comorbidity-card:hover {
    border-color: rgba(26, 24, 22, 0.25);
    background: rgba(26, 24, 22, 0.04);
  }
  .light-mode .comorbidity-card.selected {
    border-color: rgba(42, 157, 143, 0.5);
    background: rgba(42, 157, 143, 0.08);
  }
  .light-mode .comorbidity-checkbox {
    border-color: rgba(26, 24, 22, 0.25);
  }

  /* ── Sticky Header ── */
  .intake-sticky-header {
    background: #1A1816;
  }
  .light-mode .intake-sticky-header {
    background: #F5F0EA;
  }

  /* ── Safety Question Cards (Step 9) ── */
  .safety-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border: 1px solid rgba(245, 240, 234, 0.12);
    border-radius: 14px;
    padding: 18px 20px;
    background: rgba(245, 240, 234, 0.02);
  }
  .safety-btn {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: 9999px;
    border: 1.5px solid rgba(245, 240, 234, 0.18);
    background: transparent;
    color: rgba(245, 240, 234, 0.35);
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }
  .safety-btn:hover:not(.selected) {
    border-color: rgba(245, 240, 234, 0.3);
    color: rgba(245, 240, 234, 0.6);
  }
  /* No selected → teal (same as all other form selections) */
  .safety-btn[data-answer="no"].selected {
    background: rgba(42, 157, 143, 0.1);
    border-color: #2A9D8F;
    color: #2A9D8F;
  }
  /* Yes selected → red warning */
  .safety-btn[data-answer="yes"].selected {
    background: rgba(224, 82, 82, 0.1);
    border-color: #E05252;
    color: #E05252;
  }
  /* Light mode */
  .light-mode .safety-card {
    border-color: rgba(26, 24, 22, 0.12);
    background: rgba(26, 24, 22, 0.02);
  }
  .light-mode .safety-btn {
    border-color: rgba(26, 24, 22, 0.18);
    color: rgba(26, 24, 22, 0.35);
  }
  .light-mode .safety-btn[data-answer="no"].selected {
    background: rgba(42, 157, 143, 0.1);
    border-color: #2A9D8F;
    color: #2A9D8F;
  }
  .light-mode .safety-btn[data-answer="yes"].selected {
    background: rgba(224, 82, 82, 0.1);
    border-color: #E05252;
    color: #E05252;
  }

  /* Light mode overrides for checkout step */
  .light-mode .co-summary-box { background: rgba(26, 24, 22, 0.04); border-color: rgba(26, 24, 22, 0.1); }
  .light-mode .co-label { color: rgba(26, 24, 22, 0.5); }
  .light-mode .co-input { color: #1A1816; background: rgba(26, 24, 22, 0.05); border-color: rgba(26, 24, 22, 0.12); }
  .light-mode .co-input::placeholder { color: rgba(26, 24, 22, 0.3); }
  .light-mode .co-input:focus { border-color: rgba(26, 24, 22, 0.3); }
  .light-mode .co-input-bare { color: #1A1816; }
  .light-mode .co-input-bare::placeholder { color: rgba(26, 24, 22, 0.3); }
  .light-mode .co-express-btn--apple { background: #1A1816; }

  /* ── Step 11: Founder & Trust ── */
  .founder-card {
    background: rgba(255, 255, 255, 0.03);
  }
  .trust-badges-card {
    background: rgba(255, 255, 255, 0.03);
  }
  /* NABP logo: invert so it shows white on dark */
  .nabp-logo {
    filter: brightness(0) invert(1);
    opacity: 0.7;
  }

  /* Light mode overrides for Step 11 */
  .light-mode .founder-card {
    background: rgba(26, 24, 22, 0.04);
    border-color: rgba(26, 24, 22, 0.1);
  }
  .light-mode .trust-badges-card {
    background: rgba(26, 24, 22, 0.04);
    border-color: rgba(26, 24, 22, 0.1);
  }
  .light-mode .intake-divider-v {
    background: rgba(26, 24, 22, 0.1);
  }
  .light-mode .nabp-logo {
    filter: none;
    opacity: 1;
  }

  /* ── Step 12: Medications ── */
  .med-search-input {
    color: #f5f0ea;
    background: rgba(255,255,255,0.04);
  }
  .med-search-input:focus {
    background: rgba(255,255,255,0.06);
  }

  /* Accordion body — hidden by default, revealed with max-height */
  .med-cat-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .med-cat-body.med-cat-open {
    max-height: 400px;
  }

  /* Medication pill */
  .med-pill {
    display: inline-flex;
    align-items: center;
    padding: 7px 16px;
    border-radius: 999px;
    border: 1px solid rgba(245,240,234,0.15);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: rgba(245,240,234,0.7);
    background: transparent;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
    white-space: nowrap;
  }
  .med-pill:hover {
    border-color: rgba(245,240,234,0.35);
    color: #f5f0ea;
  }
  .med-pill.selected {
    background: rgba(42,157,143,0.12);
    border-color: #2A9D8F;
    color: #2A9D8F;
  }

  /* None/Continue button — default state */
  .med-none-btn {
    background: transparent;
    color: rgba(245,240,234,0.45);
    text-align: center;
    border: none;
    font-size: 15px;
  }
  .med-none-btn:hover {
    color: rgba(245,240,234,0.7);
  }

  /* Continue button — active state (medications selected) */
  .med-btn-active {
    background: #b87a5d;
    color: #f5f0ea;
    border-radius: 999px;
    font-size: 16px;
    transition: background 0.2s;
  }
  .med-btn-active:hover {
    background: #a56a4d;
  }

  /* Light mode overrides */
  .light-mode .med-search-input {
    color: #1A1816;
    background: rgba(26,24,22,0.05);
    border-color: rgba(26,24,22,0.12);
  }
  .light-mode .med-search-input::placeholder { color: rgba(26,24,22,0.3); }
  .light-mode .med-pill {
    border-color: rgba(26,24,22,0.15);
    color: rgba(26,24,22,0.6);
  }
  .light-mode .med-pill:hover {
    border-color: rgba(26,24,22,0.4);
    color: #1A1816;
  }
  .light-mode .med-pill.selected {
    background: rgba(42,157,143,0.08);
    border-color: #2A9D8F;
    color: #2A9D8F;
  }
  .light-mode .med-none-btn {
    color: rgba(26,24,22,0.4);
  }
  .light-mode .med-none-btn:hover {
    color: rgba(26,24,22,0.65);
  }
  .light-mode .med-cat-header {
    border-color: rgba(26,24,22,0.12);
    color: #1A1816;
  }

  /* ── Step 13: Allergies ── */
  .allergy-textarea {
    color: #f5f0ea;
    background: rgba(255,255,255,0.04);
    min-height: 140px;
  }
  .allergy-textarea:focus {
    background: rgba(255,255,255,0.06);
  }

  /* Light mode */
  .light-mode .allergy-textarea {
    color: #1A1816;
    background: rgba(26,24,22,0.04);
    border-color: rgba(26,24,22,0.12);
  }
  .light-mode .allergy-textarea::placeholder { color: rgba(26,24,22,0.3); }
  .light-mode .allergy-textarea:focus { border-color: rgba(26,24,22,0.25); }
  .light-mode #allergy-none-btn { color: rgba(26,24,22,0.35); }
  .light-mode #allergy-none-btn:hover { color: rgba(26,24,22,0.6); }

  /* ── Step 14: ID Upload ── */
  .id-upload-card {
    background: rgba(255,255,255,0.03);
    color: #f5f0ea;
  }
  .id-upload-card:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(245,240,234,0.3);
  }
  .id-upload-card:active {
    background: rgba(255,255,255,0.08);
  }
  .id-card-selected {
    border-color: #2A9D8F !important;
    background: rgba(42,157,143,0.08) !important;
  }

  /* Light mode */
  .light-mode .id-upload-card {
    background: rgba(26,24,22,0.03);
    border-color: rgba(26,24,22,0.12);
  }
  .light-mode .id-upload-card:hover {
    background: rgba(26,24,22,0.06);
    border-color: rgba(26,24,22,0.3);
  }
  .light-mode .id-upload-card span { color: #1A1816; }
  .light-mode .id-upload-card svg { color: rgba(26,24,22,0.6) !important; }

  /* ── Step 15: Body Photo Tips ── */
  .photo-tips-card {
    background: rgba(255,255,255,0.03);
  }
  .light-mode .photo-tips-card {
    background: rgba(26,24,22,0.04);
    border-color: rgba(26,24,22,0.12);
  }

  /* ── Step 16: Shipping Address ── */
  .ship-input {
    color: #f5f0ea;
    background: rgba(255,255,255,0.04);
  }
  .ship-input:focus {
    background: rgba(255,255,255,0.06);
  }
  .ship-state-field {
    background: rgba(255,255,255,0.02) !important;
    color: rgba(245,240,234,0.9);
  }

  /* Light mode */
  .light-mode .ship-input {
    color: #1A1816;
    background: rgba(26,24,22,0.04);
    border-color: rgba(26,24,22,0.12);
  }
  .light-mode .ship-input::placeholder { color: rgba(26,24,22,0.3); }
  .light-mode .ship-input:focus { border-color: rgba(26,24,22,0.25); }
  .light-mode .ship-state-field { color: rgba(26,24,22,0.8); background: rgba(26,24,22,0.02) !important; }

  /* ── Step 17: Confirmation ── */
  .confirm-next-card {
    background: rgba(255,255,255,0.03);
  }
  .confirm-check-svg circle,
  .confirm-check-svg path {
    stroke: #F5F0EA;
  }
  .light-mode .confirm-next-card {
    background: rgba(26,24,22,0.03);
    border-color: rgba(26,24,22,0.12);
  }
  .light-mode .confirm-check-svg circle,
  .light-mode .confirm-check-svg path {
    stroke: #1A1816;
  }
</style>

<script is:inline>
  (function() {
    var section = document.getElementById('intake-app');
    var counter = document.getElementById('intake-counter');
    var backBtn = document.getElementById('intake-back');
    var themeToggle = document.getElementById('theme-toggle');
    var iconSun = document.getElementById('icon-sun');
    var iconMoon = document.getElementById('icon-moon');
    var logoWhite = document.getElementById('logo-white');
    var logoBlack = document.getElementById('logo-black');

    var currentStep = 1;
    var totalQuestions = 18;
    var progressBar = document.getElementById('progress-bar');

    function updateProgress(step) {
      var pct = step === 17 ? 100 : Math.round((step / totalQuestions) * 100);
      progressBar.style.width = pct + '%';
      counter.textContent = pct + '%';
    }

    // Restore saved theme
    var savedTheme = sessionStorage.getItem('intake_theme');
    if (savedTheme === 'light') applyLight();

    // Theme toggle
    themeToggle?.addEventListener('click', function() {
      if (section.classList.contains('light-mode')) {
        applyDark();
        sessionStorage.setItem('intake_theme', 'dark');
      } else {
        applyLight();
        sessionStorage.setItem('intake_theme', 'light');
      }
    });

    function applyLight() {
      section.classList.add('light-mode');
      iconSun.classList.add('hidden');
      iconMoon.classList.remove('hidden');
      logoWhite.classList.add('hidden');
      logoBlack.classList.remove('hidden');
    }
    function applyDark() {
      section.classList.remove('light-mode');
      iconSun.classList.remove('hidden');
      iconMoon.classList.add('hidden');
      logoWhite.classList.remove('hidden');
      logoBlack.classList.add('hidden');
    }

    // Back button
    backBtn?.addEventListener('click', function() {
      if (currentStep === 17) {
        window.location.href = '/';
      } else if (currentStep === 1) {
        window.location.href = '/get-started';
      } else {
        goToStep(currentStep - 1);
      }
    });

    // Exit modal
    var exitModal = document.getElementById('exit-modal');
    function showExitModal() {
      exitModal.classList.remove('hidden');
      exitModal.classList.add('flex');
    }
    function hideExitModal() {
      exitModal.classList.add('hidden');
      exitModal.classList.remove('flex');
    }
    document.getElementById('exit-modal-stay')?.addEventListener('click', hideExitModal);
    document.getElementById('exit-modal-overlay')?.addEventListener('click', hideExitModal);
    document.getElementById('exit-modal-leave')?.addEventListener('click', function() {
      window.location.href = '/get-started';
    });

    // Step navigation with transitions
    function goToStep(step) {
      var prevStep = currentStep;
      var goingForward = step > prevStep;
      var container = document.getElementById('intake-content');

      // Fade out only the current active step
      var prevActive = document.getElementById('step-' + prevStep + '-active');
      if (prevActive && !prevActive.classList.contains('hidden')) {
        prevActive.classList.remove('step-visible');
        prevActive.classList.add('step-exit');
      }

      setTimeout(function() {
        // Hide the exited step
        if (prevActive) {
          prevActive.classList.add('hidden');
          prevActive.classList.remove('step-exit', 'step-enter', 'step-visible');
        }

        if (goingForward) {
          // Collapse only the step we just completed
          var prevCollapsed = document.getElementById('step-' + prevStep + '-collapsed');
          if (prevCollapsed) {
            prevCollapsed.classList.remove('hidden');
            prevCollapsed.classList.add('collapsed-enter');
            requestAnimationFrame(function() {
              requestAnimationFrame(function() {
                prevCollapsed.classList.remove('collapsed-enter');
                prevCollapsed.classList.add('collapsed-visible');
              });
            });
          }
        } else {
          // Going backward — un-collapse steps from current back to target
          for (var i = step; i <= prevStep; i++) {
            var c = document.getElementById('step-' + i + '-collapsed');
            if (c) {
              c.classList.add('hidden');
              c.classList.remove('collapsed-visible', 'collapsed-enter');
            }
          }
        }

        // Show and animate the new active step
        var activeEl = document.getElementById('step-' + step + '-active');
        if (activeEl) {
          activeEl.classList.remove('hidden');
          activeEl.classList.add('step-enter');
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              activeEl.classList.remove('step-enter');
              activeEl.classList.add('step-visible');

              // Scroll the new step into view inside the scroll container
              if (container) {
                var containerRect = container.getBoundingClientRect();
                var elRect = activeEl.getBoundingClientRect();
                var scrollTarget = elRect.top - containerRect.top + container.scrollTop - 16;
                container.scrollTo({ top: Math.max(0, scrollTarget), behavior: 'smooth' });
              }
            });
          });
        }

        currentStep = step;
        updateProgress(step);

        // Update back button label
        var phaseLabel = document.getElementById('intake-phase');
        if (phaseLabel) {
          phaseLabel.textContent = step === 17 ? 'Exit' : 'Back';
        }
      }, 160);
    }

    // ===== STEP 1: State selection =====
    var stateButtons = document.querySelectorAll('.state-btn');
    stateButtons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        stateButtons.forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');
        var state = btn.textContent.trim();
        sessionStorage.setItem('intake_state', state);
        document.getElementById('step-1-answer').textContent = state;

        // Hide "not on list" message if visible
        var notMsg = document.getElementById('state-not-msg');
        if (notMsg) notMsg.classList.add('hidden');

        // Advance to step 2 after brief delay
        setTimeout(function() { goToStep(2); }, 300);
      });
    });

    // "State not on the list?" — show message
    document.getElementById('state-not-listed')?.addEventListener('click', function() {
      var msg = document.getElementById('state-not-msg');
      if (msg) msg.classList.remove('hidden');
    });

    // Edit buttons — go back to that step
    document.querySelectorAll('.edit-step-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var step = parseInt(btn.getAttribute('data-edit-step'));
        goToStep(step);
      });
    });

    // ===== STEP 2: DOB + Sex =====
    // Auto-format DOB input
    var dobInput = document.getElementById('dob-input');
    dobInput?.addEventListener('input', function(e) {
      var val = dobInput.value.replace(/\D/g, '');
      if (val.length >= 4) {
        val = val.slice(0, 2) + '/' + val.slice(2, 4) + '/' + val.slice(4, 8);
      } else if (val.length >= 2) {
        val = val.slice(0, 2) + '/' + val.slice(2);
      }
      dobInput.value = val;
    });

    // Sex selection — advance to step 3
    var sexButtons = document.querySelectorAll('.sex-btn');
    sexButtons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        sexButtons.forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');
        var sex = btn.getAttribute('data-value');
        sessionStorage.setItem('intake_sex', sex);

        // Update step 2 collapsed answer
        var dob = document.getElementById('dob-input').value || '';
        var answerText = dob + ' · ' + sex.toLowerCase();
        document.getElementById('step-2-answer').textContent = answerText;

        setTimeout(function() { goToStep(3); }, 300);
      });
    });

    // ===== STEP 3: Height + Weight Steppers =====
    var stepperLimits = {
      'height-ft': { min: 3, max: 8 },
      'height-in': { min: 0, max: 11 },
      'weight-lbs': { min: 50, max: 500 }
    };

    document.querySelectorAll('.stepper-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var targetId = btn.getAttribute('data-target');
        var dir = parseInt(btn.getAttribute('data-dir'));
        var el = document.getElementById(targetId);
        if (!el) return;
        var current = parseInt(el.textContent);
        var limits = stepperLimits[targetId];
        var next = current + dir;
        if (next < limits.min) next = limits.min;
        if (next > limits.max) next = limits.max;
        el.textContent = next;
      });
    });

    // Step 3 continue button
    var step3Continue = document.getElementById('step-3-continue');
    step3Continue?.addEventListener('click', function() {
      var ft = document.getElementById('height-ft').textContent;
      var inches = document.getElementById('height-in').textContent;
      var lbs = document.getElementById('weight-lbs').textContent;
      var heightStr = ft + "'" + inches + '"';
      sessionStorage.setItem('intake_height', heightStr);
      sessionStorage.setItem('intake_weight', lbs);
      document.getElementById('step-3-answer').textContent = heightStr + ' · ' + lbs + ' lbs';
      goToStep(4);
    });

    // ===== STEP 4: Goals (multi-select) =====
    var selectedGoals = [];
    var step4Continue = document.getElementById('step-4-continue');
    document.querySelectorAll('.goal-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        btn.classList.toggle('selected');
        var val = btn.getAttribute('data-value');
        var idx = selectedGoals.indexOf(val);
        if (idx > -1) {
          selectedGoals.splice(idx, 1);
        } else {
          selectedGoals.push(val);
        }
        sessionStorage.setItem('intake_goals', JSON.stringify(selectedGoals));
        if (selectedGoals.length > 0) {
          step4Continue.classList.remove('hidden');
        } else {
          step4Continue.classList.add('hidden');
        }
      });
    });

    step4Continue?.addEventListener('click', function() {
      // Update step 4 collapsed answer
      var goalText = selectedGoals.join(', ');
      document.getElementById('step-4-answer').textContent = goalText;
      goToStep(5);
    });

    // ===== STEP 5: GLP-1 Experience (single-select) =====
    document.querySelectorAll('#glp1-options .option-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('#glp1-options .option-btn').forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');
        sessionStorage.setItem('intake_glp1', btn.getAttribute('data-value'));
        document.getElementById('step-5-answer').textContent = btn.getAttribute('data-value');
        setTimeout(function() { goToStep(6); }, 300);
      });
    });

    // ===== STEP 6: Account setup → step 7 =====
    document.getElementById('step-6-continue')?.addEventListener('click', function() {
      var email = document.getElementById('account-email').value.trim();
      if (!email) { document.getElementById('account-email').focus(); return; }
      sessionStorage.setItem('intake_email', email);
      var ans = document.getElementById('step-6-answer');
      if (ans) ans.textContent = email;
      goToStep(7);
    });

    // ===== STEP 7: Plan / Pricing =====
    var pricingData = {
      sema:  { monthly: 179, '3month': 149, '6month': 129 },
      tirz:  { monthly: 299, '3month': 249, '6month': 219 }
    };
    var selectedMed = 'sema';
    var selectedCommit = '6month';

    function updatePricing() {
      var semaPrice = pricingData.sema[selectedCommit];
      var tirzPrice = pricingData.tirz[selectedCommit];
      document.getElementById('price-sema').textContent = '$' + semaPrice;
      document.getElementById('price-tirz').textContent = '$' + tirzPrice;

      var activePrice = selectedMed === 'sema' ? semaPrice : tirzPrice;
      var activeName = selectedMed === 'sema'
        ? 'Compounded Semaglutide + L-Carnitine (CarniSema\u00ae)'
        : 'Compounded Tirzepatide + L-Carnitine (CarniTide\u00ae)';
      document.getElementById('summary-product-name').textContent = activeName;
      document.getElementById('summary-product-price').textContent = '$' + activePrice + '/mo';
      document.getElementById('summary-due').textContent = '$' + activePrice;
    }

    // Medication card selection
    document.querySelectorAll('.plan-med-card').forEach(function(card) {
      card.addEventListener('click', function() {
        document.querySelectorAll('.plan-med-card').forEach(function(c) { c.classList.remove('selected'); });
        card.classList.add('selected');
        selectedMed = card.getAttribute('data-med');
        updatePricing();
      });
    });

    // Commitment toggle
    document.querySelectorAll('.commit-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.commit-btn').forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');
        selectedCommit = btn.getAttribute('data-commit');
        updatePricing();
      });
    });

    // Tirzepatide: save 27% on 6-month
    document.querySelector('.commit-btn[data-commit="6month"] .commit-save') && (function() {
      // Update tirz save % dynamically handled in updatePricing via raw prices
    })();

    updatePricing();

    // Step 7 CTA → step 8 checkout
    document.getElementById('step-7-continue')?.addEventListener('click', function() {
      var price = pricingData[selectedMed][selectedCommit];
      var name = selectedMed === 'sema' ? 'CarniSema\u00ae' : 'CarniTide\u00ae';
      var commitLabels = { monthly: 'Monthly Plan', '3month': '3-Month Plan', '6month': '6-Month Plan' };

      // Update step-7 collapsed answer
      var ans = document.getElementById('step-7-answer');
      if (ans) ans.textContent = name + ' \u00b7 $' + price + '/mo';

      // Populate step 8 order summary
      var sumName = document.getElementById('co-summary-name');
      var sumCommit = document.getElementById('co-summary-commit');
      var sumPrice = document.getElementById('co-summary-price');
      var sumDue = document.getElementById('co-summary-due');
      if (sumName) sumName.textContent = name;
      if (sumCommit) sumCommit.textContent = commitLabels[selectedCommit] || '6-Month Plan';
      if (sumPrice) sumPrice.textContent = '$' + price + '/mo';
      if (sumDue) sumDue.textContent = '$' + price;

      // Pre-fill email from step 6
      var email = document.getElementById('account-email')?.value;
      var coEmail = document.getElementById('co-email');
      if (email && coEmail) coEmail.value = email;

      goToStep(8);
    });

    // ===== STEP 8: Checkout =====
    // Card number formatting
    document.getElementById('co-card')?.addEventListener('input', function(e) {
      var v = e.target.value.replace(/\D/g, '').substring(0, 16);
      e.target.value = v.replace(/(.{4})/g, '$1 ').trim();
    });

    // Expiry formatting
    document.getElementById('co-expiry')?.addEventListener('input', function(e) {
      var v = e.target.value.replace(/\D/g, '').substring(0, 4);
      if (v.length >= 3) v = v.substring(0, 2) + ' / ' + v.substring(2);
      e.target.value = v;
    });

    // Express checkout buttons
    function handleExpressCheckout(method) {
      var btnMap = { apple: 'co-btn-apple', google: 'co-btn-google', shop: 'co-btn-shop' };
      var btn = document.getElementById(btnMap[method]);
      if (btn) {
        btn.querySelector('span').textContent = 'Processing...';
        btn.disabled = true;
      }
    }
    document.getElementById('co-btn-apple')?.addEventListener('click', function() { handleExpressCheckout('apple'); });
    document.getElementById('co-btn-google')?.addEventListener('click', function() { handleExpressCheckout('google'); });
    document.getElementById('co-btn-shop')?.addEventListener('click', function() { handleExpressCheckout('shop'); });

    // Submit → step 9
    document.getElementById('co-submit')?.addEventListener('click', function() {
      var btn = this;
      btn.textContent = 'Processing...';
      btn.disabled = true;
      var ans = document.getElementById('step-8-answer');
      if (ans) ans.textContent = 'Card on file';
      setTimeout(function() {
        btn.textContent = 'Start my plan';
        btn.disabled = false;
        goToStep(9);
      }, 900);
    });

    // ===== STEP 9: Safety Questions =====
    document.querySelectorAll('.safety-card').forEach(function(card) {
      card.querySelectorAll('.safety-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          card.querySelectorAll('.safety-btn').forEach(function(b) { b.classList.remove('selected'); });
          btn.classList.add('selected');
        });
      });
    });

    document.getElementById('step-9-continue')?.addEventListener('click', function() {
      goToStep(10);
    });

    // ===== STEP 10: Comorbidities =====
    var selectedComorbidities = [];
    var step10Continue = document.getElementById('step-10-continue');

    document.querySelectorAll('.comorbidity-card').forEach(function(card) {
      card.addEventListener('click', function() {
        var val = card.getAttribute('data-value');
        var isNone = card.classList.contains('comorbidity-card--none');

        if (isNone) {
          // "None of the above" — deselect everything else, select only this
          document.querySelectorAll('.comorbidity-card').forEach(function(c) { c.classList.remove('selected'); });
          card.classList.add('selected');
          selectedComorbidities = ['None of the above'];
        } else {
          // Deselect "None of the above" if present
          document.querySelector('.comorbidity-card--none')?.classList.remove('selected');
          var noneIdx = selectedComorbidities.indexOf('None of the above');
          if (noneIdx > -1) selectedComorbidities.splice(noneIdx, 1);
          // Toggle this card
          if (card.classList.contains('selected')) {
            card.classList.remove('selected');
            selectedComorbidities = selectedComorbidities.filter(function(v) { return v !== val; });
          } else {
            card.classList.add('selected');
            selectedComorbidities.push(val);
          }
        }

        // Show/hide continue button
        if (selectedComorbidities.length > 0) {
          step10Continue?.classList.remove('hidden');
        } else {
          step10Continue?.classList.add('hidden');
        }
      });
    });

    step10Continue?.addEventListener('click', function() {
      sessionStorage.setItem('intake_comorbidities', JSON.stringify(selectedComorbidities));
      var ans = document.getElementById('step-10-answer');
      if (ans) ans.textContent = selectedComorbidities.length === 1 ? selectedComorbidities[0] : selectedComorbidities.length + ' conditions';
      goToStep(11);
    });

    // ===== STEP 11: Meet the Founder =====
    document.getElementById('step-11-continue')?.addEventListener('click', function() {
      goToStep(12);
    });

    // ===== STEP 12: Current Medications =====
    var selectedMedications = [];

    // Accordion toggle
    document.querySelectorAll('.med-cat-header').forEach(function(header) {
      header.addEventListener('click', function() {
        var category = header.closest('.med-category');
        var body = category.querySelector('.med-cat-body');
        var chevron = header.querySelector('.med-cat-chevron');
        var isOpen = body.classList.contains('med-cat-open');
        if (isOpen) {
          body.classList.remove('med-cat-open');
          chevron.style.transform = 'rotate(0deg)';
        } else {
          body.classList.add('med-cat-open');
          chevron.style.transform = 'rotate(180deg)';
        }
      });
    });

    // Medication pill selection
    document.querySelectorAll('.med-pill').forEach(function(pill) {
      pill.addEventListener('click', function() {
        var med = pill.getAttribute('data-med');
        if (pill.classList.contains('selected')) {
          pill.classList.remove('selected');
          selectedMedications = selectedMedications.filter(function(m) { return m !== med; });
        } else {
          pill.classList.add('selected');
          selectedMedications.push(med);
        }
        updateMedBtn();
      });
    });

    function updateMedBtn() {
      var btn = document.getElementById('step-12-continue');
      if (!btn) return;
      if (selectedMedications.length > 0) {
        btn.textContent = 'Continue (' + selectedMedications.length + ' selected)';
        btn.classList.add('med-btn-active');
        btn.classList.remove('med-none-btn');
      } else {
        btn.textContent = 'None \u2014 Continue';
        btn.classList.remove('med-btn-active');
        btn.classList.add('med-none-btn');
      }
    }

    // Search / filter
    document.getElementById('med-search')?.addEventListener('input', function() {
      var query = this.value.trim().toLowerCase();
      document.querySelectorAll('.med-category').forEach(function(cat) {
        var pills = cat.querySelectorAll('.med-pill');
        var anyMatch = false;
        pills.forEach(function(pill) {
          var name = pill.getAttribute('data-med').toLowerCase();
          var match = !query || name.includes(query);
          pill.style.display = match ? '' : 'none';
          if (match) anyMatch = true;
        });
        // Show/hide category
        cat.style.display = anyMatch ? '' : 'none';
        // Auto-expand if searching
        if (query && anyMatch) {
          var body = cat.querySelector('.med-cat-body');
          var chevron = cat.querySelector('.med-cat-chevron');
          body.classList.add('med-cat-open');
          chevron.style.transform = 'rotate(180deg)';
        } else if (!query) {
          // Restore collapsed state on clear
          var body = cat.querySelector('.med-cat-body');
          var chevron = cat.querySelector('.med-cat-chevron');
          body.classList.remove('med-cat-open');
          chevron.style.transform = 'rotate(0deg)';
        }
      });
    });

    // Step 12 continue
    document.getElementById('step-12-continue')?.addEventListener('click', function() {
      sessionStorage.setItem('intake_medications', JSON.stringify(selectedMedications));
      var ans = document.getElementById('step-12-answer');
      if (ans) ans.textContent = selectedMedications.length > 0 ? selectedMedications.length + ' selected' : 'None';
      goToStep(13);
    });

    // ===== STEP 13: Allergies =====
    var allergyInput = document.getElementById('allergy-input');
    var allergyNoneBtn = document.getElementById('allergy-none-btn');
    var step13Continue = document.getElementById('step-13-continue');

    function updateAllergyBtn() {
      var val = allergyInput ? allergyInput.value.trim() : '';
      if (val.length > 0) {
        step13Continue?.classList.remove('hidden');
      } else {
        step13Continue?.classList.add('hidden');
      }
    }

    allergyInput?.addEventListener('input', updateAllergyBtn);

    allergyNoneBtn?.addEventListener('click', function() {
      if (allergyInput) {
        allergyInput.value = 'None';
        updateAllergyBtn();
        allergyInput.focus();
      }
    });

    step13Continue?.addEventListener('click', function() {
      var val = allergyInput ? allergyInput.value.trim() : 'None';
      sessionStorage.setItem('intake_allergies', val);
      var ans = document.getElementById('step-13-answer');
      if (ans) ans.textContent = val.length > 20 ? val.substring(0, 20) + '…' : val;
      goToStep(14);
    });

    // ===== STEP 14: ID Verification =====
    var idCameraInput = document.getElementById('id-camera-input');
    var idFileInput = document.getElementById('id-file-input');
    var idPreview = document.getElementById('id-preview');
    var idPreviewImg = document.getElementById('id-preview-img');
    var idPreviewName = document.getElementById('id-preview-name');
    var step14Continue = document.getElementById('step-14-continue');

    document.getElementById('id-take-photo')?.addEventListener('click', function() {
      idCameraInput?.click();
    });

    document.getElementById('id-upload-file')?.addEventListener('click', function() {
      idFileInput?.click();
    });

    function handleIdFile(file) {
      if (!file) return;
      var reader = new FileReader();
      reader.onload = function(e) {
        if (idPreviewImg) idPreviewImg.src = e.target.result;
        if (idPreviewName) idPreviewName.textContent = file.name;
        idPreview?.classList.remove('hidden');
        step14Continue?.classList.remove('hidden');
        // Mark selected cards
        document.querySelectorAll('.id-upload-card').forEach(function(c) { c.classList.remove('id-card-selected'); });
      };
      reader.readAsDataURL(file);
    }

    idCameraInput?.addEventListener('change', function() {
      if (this.files && this.files[0]) handleIdFile(this.files[0]);
    });

    idFileInput?.addEventListener('change', function() {
      if (this.files && this.files[0]) handleIdFile(this.files[0]);
    });

    document.getElementById('id-clear')?.addEventListener('click', function() {
      if (idPreviewImg) idPreviewImg.src = '';
      if (idPreviewName) idPreviewName.textContent = '';
      idPreview?.classList.add('hidden');
      step14Continue?.classList.add('hidden');
      if (idCameraInput) idCameraInput.value = '';
      if (idFileInput) idFileInput.value = '';
    });

    step14Continue?.addEventListener('click', function() {
      sessionStorage.setItem('intake_id_uploaded', 'true');
      goToStep(15);
    });

    // ===== STEP 15: Body Photo =====
    var bodyCameraInput = document.getElementById('body-camera-input');
    var bodyFileInput = document.getElementById('body-file-input');
    var bodyPreview = document.getElementById('body-preview');
    var bodyPreviewImg = document.getElementById('body-preview-img');
    var bodyPreviewName = document.getElementById('body-preview-name');
    var step15Continue = document.getElementById('step-15-continue');

    document.getElementById('body-take-photo')?.addEventListener('click', function() {
      bodyCameraInput?.click();
    });

    document.getElementById('body-upload-file')?.addEventListener('click', function() {
      bodyFileInput?.click();
    });

    function handleBodyFile(file) {
      if (!file) return;
      var reader = new FileReader();
      reader.onload = function(e) {
        if (bodyPreviewImg) bodyPreviewImg.src = e.target.result;
        if (bodyPreviewName) bodyPreviewName.textContent = file.name;
        bodyPreview?.classList.remove('hidden');
        step15Continue?.classList.remove('hidden');
      };
      reader.readAsDataURL(file);
    }

    bodyCameraInput?.addEventListener('change', function() {
      if (this.files && this.files[0]) handleBodyFile(this.files[0]);
    });

    bodyFileInput?.addEventListener('change', function() {
      if (this.files && this.files[0]) handleBodyFile(this.files[0]);
    });

    document.getElementById('body-clear')?.addEventListener('click', function() {
      if (bodyPreviewImg) bodyPreviewImg.src = '';
      if (bodyPreviewName) bodyPreviewName.textContent = '';
      bodyPreview?.classList.add('hidden');
      step15Continue?.classList.add('hidden');
      if (bodyCameraInput) bodyCameraInput.value = '';
      if (bodyFileInput) bodyFileInput.value = '';
    });

    step15Continue?.addEventListener('click', function() {
      sessionStorage.setItem('intake_body_photo_uploaded', 'true');
      // Pre-fill state from step 1 selection
      var stateField = document.getElementById('ship-state');
      if (stateField) {
        var savedState = sessionStorage.getItem('intake_state') || '';
        stateField.value = savedState;
      }
      goToStep(16);
    });

    // ===== STEP 16: Shipping Address =====
    var shipFields = ['ship-street', 'ship-city', 'ship-zip'];

    function checkShipForm() {
      var allFilled = shipFields.every(function(id) {
        var el = document.getElementById(id);
        return el && el.value.trim().length > 0;
      });
      var btn = document.getElementById('step-16-continue');
      if (btn) {
        if (allFilled) btn.classList.remove('hidden');
        else btn.classList.add('hidden');
      }
    }

    ['ship-street', 'ship-apt', 'ship-city', 'ship-zip'].forEach(function(id) {
      document.getElementById(id)?.addEventListener('input', checkShipForm);
    });

    // ZIP: digits only
    document.getElementById('ship-zip')?.addEventListener('input', function() {
      this.value = this.value.replace(/[^\d-]/g, '');
    });

    document.getElementById('step-16-continue')?.addEventListener('click', function() {
      var address = {
        street: document.getElementById('ship-street')?.value.trim(),
        apt: document.getElementById('ship-apt')?.value.trim(),
        city: document.getElementById('ship-city')?.value.trim(),
        state: document.getElementById('ship-state')?.value.trim(),
        zip: document.getElementById('ship-zip')?.value.trim()
      };
      sessionStorage.setItem('intake_shipping', JSON.stringify(address));
      var ans = document.getElementById('step-16-answer');
      if (ans) {
        ans.textContent = (address.city && address.state)
          ? address.city + ', ' + address.state
          : 'Saved';
      }
      goToStep(17);
    });

  })();
</script>
