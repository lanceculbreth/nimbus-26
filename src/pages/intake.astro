    background: transparent;
  }
  .sex-btn.selected {
    border-color: #2A9D8F;
    background: rgba(42, 157, 143, 0.1);
    color: #2A9D8F;
  }

  /* Step transitions — subtle */
  .step-enter {
    opacity: 0;
    transform: translateY(8px);
  }
  .step-visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.28s ease, transform 0.28s ease;
  }
  .step-exit {
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .collapsed-enter {
    opacity: 0;
  }
  .collapsed-visible {
    opacity: 1;
    transition: opacity 0.2s ease;
  }

  /* Light mode overrides */
  .light-mode {
    background-color: #F5F0EA !important;
  }
  .light-mode .intake-heading {
    color: #1A1816;
  }
  .light-mode .intake-body {
    color: rgba(26, 24, 22, 0.55);
  }
  .light-mode .intake-bold {
    color: #1A1816;
  }
  .light-mode .intake-muted {
    color: rgba(26, 24, 22, 0.4);
  }
  .light-mode .intake-back-btn {
    border-color: rgba(26, 24, 22, 0.15);
    color: rgba(26, 24, 22, 0.5);
  }
  .light-mode .intake-back-btn:hover {
    border-color: rgba(26, 24, 22, 0.3);
    color: #1A1816;
  }
  .light-mode .intake-label {
