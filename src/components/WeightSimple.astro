---
---

<section class="pb-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Text Row -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12" data-animate>
      <h2 class="font-fraunces text-dark text-[clamp(32px,4vw,56px)] leading-[1.1] tracking-[-0.02em] max-w-[550px]">
        No dose anxiety.<br />
        No comparison paralysis.
      </h2>
      <div class="max-w-[360px]">
        <p class="font-inter text-dark/60 text-sm leading-[1.7] mb-6">
          No complicated protocols. No constant check-ins. Just care that fits your life.
        </p>
        <a href="/get-started" class="bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-sm rounded-full px-8 py-4 inline-block transition-colors">
          Find your path
        </a>
      </div>
    </div>

    <!-- Video -->
    <div class="rounded-2xl overflow-hidden" data-animate data-delay="1">
      <video
        src="/videos/Yoga_Slow.mp4"
        class="w-full object-cover"
        autoplay
        loop
        muted
        playsinline
      ></video>
    </div>
  </div>
</section>
