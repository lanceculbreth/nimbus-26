---
import photo1 from '../assets/[4] Product Imagery & Video/iStock-1337452483123123 1 (1).png';
import photo2 from '../assets/[4] Product Imagery & Video/iStock-2203624688.jpg';
import photo3 from '../assets/[4] Product Imagery & Video/iStock-2210163746.jpg';
---

<section class="pb-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Text Row -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12" data-animate>
      <h2 class="font-fraunces text-dark text-[clamp(32px,4vw,56px)] leading-[1.1] tracking-[-0.02em] max-w-[550px]">
        No dose anxiety.<br />
        No comparison paralysis.
      </h2>
      <div class="max-w-[360px]">
        <p class="font-inter text-dark/60 text-sm leading-[1.7] mb-6">
          No complicated protocols. No constant check-ins. Just care that fits your life.
        </p>
        <a href="/get-started" class="bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-sm rounded-full px-8 py-4 inline-block transition-colors">
          Find your path
        </a>
      </div>
    </div>

    <!-- Image Grid -->
    <div class="grid grid-cols-3 gap-4" data-animate data-delay="1">
      <div class="rounded-2xl overflow-hidden">
        <img src={photo1.src} alt="Mother and child" class="w-full aspect-[4/5] object-cover" loading="lazy" />
      </div>
      <div class="rounded-2xl overflow-hidden">
        <img src={photo2.src} alt="Woman smiling" class="w-full aspect-[4/5] object-cover" loading="lazy" />
      </div>
      <div class="rounded-2xl overflow-hidden">
        <img src={photo3.src} alt="Father and son" class="w-full aspect-[4/5] object-cover" loading="lazy" />
      </div>
    </div>
  </div>
</section>
