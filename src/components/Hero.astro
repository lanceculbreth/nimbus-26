---
import heroBg from '../assets/images/hero-bg.jpg';
---

<!-- Video Hero -->
<section class="relative w-full h-[100vh] md:h-[100vh] p-0 md:p-[10px]">
  <!-- Background Video -->
  <div class="absolute inset-0 md:inset-[10px] rounded-none md:rounded-[14px] overflow-hidden">
    <video
      autoplay
      muted
      loop
      playsinline
      poster={heroBg.src}
      class="w-full h-full object-cover"
    >
      <source src="/videos/groove hero 1.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-[#1A1816]/50"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-start md:items-center justify-end md:justify-center h-full text-left md:text-center px-6 md:px-4 pt-20 pb-[126px] md:pb-0">
    <h1 class="hero-animate font-fraunces text-cream text-[clamp(60pt,10vw,100pt)] leading-[0.85] tracking-[-0.01em] mb-12">
      Find your<br class="md:hidden" /> groove.
    </h1>

    <p class="hero-animate hero-animate-delay-1 font-inter text-cream text-[15px] md:text-[20px] leading-[1.3] tracking-[-0.01em] max-w-[750px] mb-12">
      Doctor-led metabolic care, including GLP-1 weight care
      and hormone optimization, personalized to your body,
      your rhythm, your real life.
    </p>

    <div class="hero-animate hero-animate-delay-2 flex flex-col items-start md:items-center gap-4">
      <a
        href="/get-started"
        class="bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-base rounded-full px-8 md:px-16 py-4.5 transition-colors text-center md:w-[260px]"
      >
        Find your path
      </a>
      <a
        href="/login"
        class="hidden md:block bg-white/30 backdrop-blur-xl text-cream font-montserrat font-medium text-base rounded-full px-16 py-4.5 hover:bg-white/40 transition-colors text-center md:w-[260px]"
      >
        Login
      </a>
    </div>
  </div>

  <!-- Trust Bar — desktop: overlaid at bottom -->
  <div class="hidden md:block absolute bottom-0 md:bottom-[10px] left-0 md:left-[10px] right-0 md:right-[10px] z-10">
    <div class="hero-animate hero-animate-delay-3 flex flex-wrap items-center justify-center gap-x-10 gap-y-3 rounded-b-none md:rounded-b-[14px] py-5 px-6">
      <div class="flex items-center gap-2 text-cream">
        <svg class="w-[18px] h-[18px]" viewBox="0 0 18 18" fill="none"><path d="M2 14V8h3v6H2zm5.5 0V4h3v10h-3zM13 14V1h3v13h-3z" fill="currentColor"/></svg>
        <span class="font-inter font-medium text-sm text-cream whitespace-nowrap">94% patient success rate</span>
      </div>
      <div class="flex items-center gap-2 text-cream">
        <svg class="w-[18px] h-[18px]" viewBox="0 0 18 18" fill="none"><path d="M9 1L2 4v5c0 4.14 2.98 8.02 7 9 4.02-.98 7-4.86 7-9V4L9 1zm0 2.04l5 2.14v3.82c0 3.31-2.38 6.41-5 7.18-2.62-.77-5-3.87-5-7.18V5.18l5-2.14z" fill="currentColor"/></svg>
        <span class="font-inter font-medium text-sm text-cream whitespace-nowrap">Licensed physicians</span>
      </div>
      <div class="flex items-center gap-2 text-cream">
        <svg class="w-[18px] h-[18px]" viewBox="0 0 18 18" fill="none"><path d="M16.5 1h-6.79a1.5 1.5 0 00-1.06.44L1.44 8.65a1.5 1.5 0 000 2.12l5.79 5.79a1.5 1.5 0 002.12 0l7.21-7.21A1.5 1.5 0 0017 8.29V2.5A1.5 1.5 0 0016.5 1zM13.5 6a1.5 1.5 0 110-3 1.5 1.5 0 010 3z" fill="currentColor"/></svg>
        <span class="font-inter font-medium text-sm text-cream whitespace-nowrap">Flat-rate pricing</span>
      </div>
      <div class="flex items-center gap-2 text-cream">
        <svg class="w-[18px] h-[18px]" viewBox="0 0 18 18" fill="none"><path d="M9 16.35l-1.45-1.32C3.4 11.36 1 9.28 1 6.5 1 4.42 2.42 3 4.5 3c1.74 0 3.41 1.01 4.5 2.09C10.09 4.01 11.76 3 13.5 3 15.58 3 17 4.42 17 6.5c0 2.78-2.4 4.86-6.55 8.54L9 16.35z" fill="currentColor"/></svg>
        <span class="font-inter font-medium text-sm text-cream whitespace-nowrap">Ongoing clinical support</span>
      </div>
      <div class="flex items-center gap-2 text-cream">
        <svg class="w-[18px] h-[18px]" viewBox="0 0 18 18" fill="none"><path d="M11 1H7v4H3v4h4v4h4V9h4V5h-4V1z" fill="currentColor"/></svg>
        <span class="font-inter font-medium text-sm text-cream whitespace-nowrap">Our own pharmacy</span>
      </div>
    </div>
  </div>
</section>

<!-- Trust Bar — mobile: below video, stacked one per line -->
<section class="md:hidden bg-cream pt-10 pb-6 px-6">
  <div class="hero-animate hero-animate-delay-3 border border-dark/15 rounded-2xl p-5 flex flex-col items-start gap-4">
    <div class="flex items-center gap-2 text-dark">
      <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 18 18" fill="none"><path d="M2 14V8h3v6H2zm5.5 0V4h3v10h-3zM13 14V1h3v13h-3z" fill="currentColor"/></svg>
      <span class="font-inter font-medium text-sm text-dark">94% patient success rate</span>
    </div>
    <div class="flex items-center gap-2 text-dark">
      <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 18 18" fill="none"><path d="M9 1L2 4v5c0 4.14 2.98 8.02 7 9 4.02-.98 7-4.86 7-9V4L9 1zm0 2.04l5 2.14v3.82c0 3.31-2.38 6.41-5 7.18-2.62-.77-5-3.87-5-7.18V5.18l5-2.14z" fill="currentColor"/></svg>
      <span class="font-inter font-medium text-sm text-dark">Licensed physicians</span>
    </div>
    <div class="flex items-center gap-2 text-dark">
      <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 18 18" fill="none"><path d="M16.5 1h-6.79a1.5 1.5 0 00-1.06.44L1.44 8.65a1.5 1.5 0 000 2.12l5.79 5.79a1.5 1.5 0 002.12 0l7.21-7.21A1.5 1.5 0 0017 8.29V2.5A1.5 1.5 0 0016.5 1zM13.5 6a1.5 1.5 0 110-3 1.5 1.5 0 010 3z" fill="currentColor"/></svg>
      <span class="font-inter font-medium text-sm text-dark">Flat-rate pricing</span>
    </div>
    <div class="flex items-center gap-2 text-dark">
      <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 18 18" fill="none"><path d="M9 16.35l-1.45-1.32C3.4 11.36 1 9.28 1 6.5 1 4.42 2.42 3 4.5 3c1.74 0 3.41 1.01 4.5 2.09C10.09 4.01 11.76 3 13.5 3 15.58 3 17 4.42 17 6.5c0 2.78-2.4 4.86-6.55 8.54L9 16.35z" fill="currentColor"/></svg>
      <span class="font-inter font-medium text-sm text-dark">Ongoing clinical support</span>
    </div>
    <div class="flex items-center gap-2 text-dark">
      <svg class="w-[18px] h-[18px] shrink-0" viewBox="0 0 18 18" fill="none"><path d="M11 1H7v4H3v4h4v4h4V9h4V5h-4V1z" fill="currentColor"/></svg>
      <span class="font-inter font-medium text-sm text-dark">Our own pharmacy</span>
    </div>
  </div>
</section>
