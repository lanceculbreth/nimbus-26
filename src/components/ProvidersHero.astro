---
---

<section class="relative w-full h-[100vh] p-0 md:p-[10px] bg-[#1A1816]">
  <!-- Background Video -->
  <div class="absolute inset-0 md:inset-[10px] rounded-none md:rounded-[14px] overflow-hidden bg-[#1A1816]">
    <video
      autoplay
      muted
      loop
      playsinline
      class="w-full h-full object-cover"
    >
      <source src="/videos/iStock-2196989613.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-dark/70"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4 pt-20">
    <h1 class="hero-animate font-fraunces text-cream text-[clamp(32pt,6vw,60pt)] leading-[1.1] tracking-[-0.01em] mb-8">
      Your <em class="italic">new</em> clinic to<br />
      pharmacy workflow
    </h1>

    <p class="hero-animate hero-animate-delay-1 font-inter text-cream/50 text-lg leading-[1.5] max-w-[600px] mb-12">
      Automated pricing, billing, tracking, and refill management so you can stop chasing prescriptions and start focusing on patient care.
    </p>

    <div class="hero-animate hero-animate-delay-2">
      <a
        href="/contact"
        class="bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-base rounded-full px-16 py-4.5 transition-colors inline-block"
      >
        Contact us
      </a>
    </div>
  </div>
</section>
