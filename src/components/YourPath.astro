---
---

<section class="pt-24 pb-2 px-[10px]">
  <div class="max-w-[1200px] mx-auto text-center">
    <!-- Label -->
    <div class="flex items-center justify-center gap-3 mb-4" data-animate>
      <div class="w-12 h-[2px] bg-teal"></div>
      <span class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase">WeightWise GLP-1 Plan</span>
      <div class="w-12 h-[2px] bg-teal"></div>
    </div>

    <!-- Heading -->
    <h2 class="font-fraunces text-dark text-[clamp(40px,5vw,72px)] leading-[1.05] tracking-[-0.02em] mb-6" data-animate data-delay="1">
      Your path. <em class="text-terracotta not-italic italic">Your plan.</em>
    </h2>

    <!-- Subtitle -->
    <p class="font-inter text-dark/70 text-base leading-[1.5] max-w-[550px] mx-auto mb-10">
      GLP-1 access. Weight management. Meal plans. Virtual consultations.<br />
      Take control of your health journey with personalized care.
    </p>

    <!-- Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <div class="flex flex-col sm:contents gap-4 w-[220px] sm:w-auto">
        <a href="/get-started" class="w-full sm:w-auto text-center bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-sm rounded-full px-6 py-3 transition-colors">
          Find your path
        </a>
        <a href="#how-it-works" class="w-full sm:w-auto text-center border border-dark/30 text-dark font-montserrat font-medium text-sm rounded-full px-6 py-3 hover:bg-dark/5 transition-colors">
          See how it works
        </a>
      </div>
    </div>

    <!-- Video -->
    <div class="max-w-[1200px] mx-auto" data-animate="scale-in">
      <video
        src="/videos/iStock-2210532095.mp4"
        autoplay
        muted
        loop
        playsinline
        class="w-full rounded-2xl object-cover aspect-[16/10]"
      ></video>
    </div>
  </div>
</section>
