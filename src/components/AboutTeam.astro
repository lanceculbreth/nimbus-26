---
import teamImg from '../assets/[4] Product Imagery & Video/iStock-1157992539.jpg';
---

<section class="bg-[#1A1816] py-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Heading -->
    <div class="text-center mb-12" data-animate>
      <h2 class="font-fraunces text-cream text-[clamp(40px,5vw,72px)] leading-[1.05] tracking-[-0.02em] mb-4">
        The team behind <em class="text-teal not-italic italic">Nimbus.</em>
      </h2>
      <p class="font-inter text-cream/50 text-base leading-[1.6] max-w-[600px] mx-auto">
        Nimbus is powered by a growing team across clinical care, pharmacy operations, engineering, and patient support—people who care deeply about making healthcare feel coordinated, predictable, and human.
      </p>
    </div>

    <!-- Team Image -->
    <div class="rounded-2xl overflow-hidden" data-animate="scale-in">
      <img
        src={teamImg.src}
        alt="The Nimbus Healthcare team"
        class="w-full aspect-[16/9] object-cover"
      />
    </div>
  </div>
</section>
