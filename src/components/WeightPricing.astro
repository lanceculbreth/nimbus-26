<script>
  const pricingData = {
    semaglutide: {
      name: 'Semaglutide',
      monthly: '$179',
      '3mo': '$149',
      '6mo': '$129',
      '3mo_save': 'save 17%',
      '6mo_save': 'save 28%',
    },
    tirzepatide: {
      name: 'Tirzepatide',
      monthly: '$299',
      '3mo': '$249',
      '6mo': '$219',
      '3mo_save': 'save 17%',
      '6mo_save': 'save 27%',
    },
  };

  const section = document.getElementById('weight-pricing');
  const toggleBtns = section.querySelectorAll('.pricing-toggle-btn');
  const drugNameEl = document.getElementById('pricing-drug-name');

  function setDrug(drug) {
    const data = pricingData[drug];
    if (drugNameEl) drugNameEl.textContent = data.name;
    section.querySelectorAll('[data-price]').forEach(el => {
      const key = el.dataset.price;
      if (data[key]) el.textContent = data[key];
    });
    section.querySelectorAll('[data-save]').forEach(el => {
      const key = el.dataset.save + '_save';
      if (data[key]) el.textContent = data[key];
    });
    toggleBtns.forEach(btn => {
      if (btn.dataset.drug === drug) {
        btn.classList.add('bg-cream', 'text-dark');
        btn.classList.remove('text-cream/60');
      } else {
        btn.classList.remove('bg-cream', 'text-dark');
        btn.classList.add('text-cream/60');
      }
    });
  }

  toggleBtns.forEach(btn => {
    btn.addEventListener('click', () => setDrug(btn.dataset.drug));
  });

  // Mobile carousel
  (function() {
    var track = document.getElementById('pricing-track');
    var dots = section.querySelectorAll('.pricing-dot');
    if (!track || dots.length === 0) return;

    var current = 0;
    var total = 3;

    function getSlideWidth() {
      var slide = track.querySelector('.pricing-slide');
      if (!slide) return 300;
      return slide.getBoundingClientRect().width;
    }

    function goTo(idx) {
      if (idx < 0) idx = 0;
      if (idx >= total) idx = total - 1;
      current = idx;
      var w = getSlideWidth();
      var gap = parseFloat(getComputedStyle(track).gap) || 16;
      track.style.transform = 'translateX(' + (-(w + gap) * current) + 'px)';
      dots.forEach(function(d, i) {
        d.classList.toggle('bg-dark', i === current);
        d.classList.toggle('bg-dark/25', i !== current);
      });
    }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        goTo(parseInt(dot.dataset.slide));
      });
    });

    // Touch/swipe
    var startX = 0, startY = 0, isDragging = false, locked = false;
    track.addEventListener('touchstart', function(e) {
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      isDragging = true;
      locked = false;
    }, { passive: true });

    track.addEventListener('touchmove', function(e) {
      if (!isDragging) return;
      var dx = e.touches[0].clientX - startX;
      var dy = e.touches[0].clientY - startY;
      if (!locked) {
        if (Math.abs(dy) > Math.abs(dx)) { isDragging = false; return; }
        locked = true;
      }
      e.preventDefault();
    }, { passive: false });

    track.addEventListener('touchend', function(e) {
      if (!isDragging) return;
      isDragging = false;
      var dx = e.changedTouches[0].clientX - startX;
      if (dx < -40) goTo(current + 1);
      else if (dx > 40) goTo(current - 1);
    }, { passive: true });
  })();
</script>
