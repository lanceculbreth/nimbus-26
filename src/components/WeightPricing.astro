        </div>
        <div class="p-10 pt-6">
          <a href="/get-started" class="border border-dark/15 text-dark font-montserrat font-medium text-sm rounded-full py-4 text-center block hover:bg-dark/5 transition-colors">
            Get started
          </a>
        </div>
      </div>
    </div>

    <!-- Mobile carousel (hidden on desktop) -->
    <div class="md:hidden" data-animate data-delay="1">
      <div class="overflow-hidden" id="pricing-carousel">
        <div class="flex gap-4 transition-transform duration-300 ease-out" id="pricing-track">

          <!-- Slide 1: 6-Month Card (Popular) - FIRST on mobile -->
          <div class="pricing-slide shrink-0 w-[calc(100vw-80px)] bg-dark rounded-2xl flex flex-col">
            <div class="p-6 pb-6">
              <div class="flex items-center justify-between mb-10">
                <p class="font-inter text-cream font-semibold text-sm">
                  6-Month <span class="font-normal text-cream/50" data-save="6mo">save 28%</span>
                </p>
                <span class="bg-teal text-cream font-montserrat text-xs font-semibold px-3.5 py-1 rounded-full">Popular</span>
              </div>
              <p class="font-fraunces text-cream text-[48px] leading-none font-bold">
                <span data-price="6mo">$129</span><span class="text-cream/40 text-lg font-normal">/mo</span>
              </p>
              <p class="font-inter text-cream/50 text-sm leading-[1.6] mt-5">
                Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut.
              </p>
            </div>
            <div class="px-6 py-6 flex flex-col gap-4 flex-1 border-t border-cream/10">
              {features.map(f => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 mt-0.5 shrink-0 text-teal" viewBox="0 0 20 20" fill="none">
                    <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="font-inter text-cream/80 text-xs">{f}</span>
                </div>
              ))}
            </div>
            <div class="p-6 pt-4">
              <a href="/get-started" class="bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-sm rounded-full py-4 text-center block transition-colors">
                Get started
              </a>
            </div>
          </div>

          <!-- Slide 2: 3-Month Card -->
          <div class="pricing-slide shrink-0 w-[calc(100vw-80px)] bg-cream rounded-2xl flex flex-col">
            <div class="p-6 pb-6">
              <p class="font-inter text-dark font-semibold text-sm mb-10">
                3-Month <span class="font-normal text-dark/50" data-save="3mo">save 17%</span>
              </p>
              <p class="font-fraunces text-dark text-[48px] leading-none font-bold">
                <span data-price="3mo">$149</span><span class="text-dark/40 text-lg font-normal">/mo</span>
              </p>
              <p class="font-inter text-dark/50 text-sm leading-[1.6] mt-5">
                Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut.
              </p>
            </div>
            <div class="px-6 py-6 flex flex-col gap-4 flex-1 border-t border-dark/8">
              {features.map(f => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 mt-0.5 shrink-0 text-teal" viewBox="0 0 20 20" fill="none">
                    <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
