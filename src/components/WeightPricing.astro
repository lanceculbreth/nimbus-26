---
const features = [
  'A personalized GLP-1 protocol tailored to your goals',
  'Regular check-ins to assess your progress',
  'Support from our clinical team',
  'Regular check-ins to assess your progress',
  'Support from our clinical team',
  'Regular check-ins to assess your progress',
];
---

<section class="px-[10px] pt-6 pb-24" id="weight-pricing">
  <div class="bg-[#EAE4DD] rounded-[14px] px-5 py-16 md:px-[50px] md:py-24">
  <div class="max-w-[1200px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-14" data-animate>
      <h2 class="font-fraunces text-dark text-[clamp(36px,4vw,56px)] leading-[1.1] tracking-[-0.02em] mb-4">
        Compounded<br />
        <strong class="font-bold" id="pricing-drug-name">Semaglutide</strong>
      </h2>
      <p class="font-inter text-dark/60 text-base leading-[1.7] max-w-[550px] mx-auto mb-10">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut.
      </p>

      <!-- Toggle -->
      <div class="inline-flex bg-dark rounded-[20px] p-[6px] mb-6">
        <button
          class="pricing-toggle-btn bg-cream text-dark font-montserrat text-sm font-medium w-[145px] h-[50px] rounded-[12px] transition-all duration-300 cursor-pointer"
          data-drug="semaglutide"
        >
          Semaglutide
        </button>
        <button
          class="pricing-toggle-btn text-cream/60 font-montserrat text-sm font-medium w-[145px] h-[50px] rounded-[12px] transition-all duration-300 cursor-pointer"
          data-drug="tirzepatide"
        >
          Tirzepatide
        </button>
      </div>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 max-w-[500px] md:max-w-none mx-auto w-full" data-animate data-delay="1">

      <!-- 6-Month Card (Popular) — first on mobile, second on desktop -->
      <div class="bg-dark rounded-2xl flex flex-col order-1 md:order-2">
        <div class="p-6 pb-6 md:p-10 md:pb-8">
          <div class="flex items-center justify-between mb-10">
            <p class="font-inter text-cream font-semibold text-sm">
              6-Month <span class="font-normal text-cream/50" data-save="6mo">save 28%</span>
            </p>
            <span class="bg-teal text-cream font-montserrat text-xs font-semibold px-3.5 py-1 rounded-full">Popular</span>
          </div>
          <p class="font-fraunces text-cream text-[48px] leading-none font-bold">
            <span data-price="6mo">$129</span><span class="text-cream/40 text-lg font-normal">/mo</span>
          </p>
          <p class="font-inter text-cream/50 text-sm leading-[1.6] mt-5">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut.
          </p>
        </div>
        <div class="px-6 md:px-10 py-6 flex flex-col gap-4 flex-1 border-t border-cream/10">
          {features.map(f => (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0 text-teal" viewBox="0 0 20 20" fill="none">
                <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
                <path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="font-inter text-cream/80 text-xs">{f}</span>
            </div>
          ))}
        </div>
        <div class="p-6 pt-4 md:p-10 md:pt-6">
          <a href="/get-started" class="bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-sm rounded-full py-4 text-center block transition-colors">
            Get started
          </a>
        </div>
      </div>

      <!-- 3-Month Card — second on mobile, first on desktop -->
      <div class="bg-cream rounded-2xl flex flex-col order-2 md:order-1">
        <div class="p-6 pb-6 md:p-10 md:pb-8">
          <p class="font-inter text-dark font-semibold text-sm mb-10">
            3-Month <span class="font-normal text-dark/50" data-save="3mo">save 17%</span>
          </p>
          <p class="font-fraunces text-dark text-[48px] leading-none font-bold">
            <span data-price="3mo">$149</span><span class="text-dark/40 text-lg font-normal">/mo</span>
          </p>
          <p class="font-inter text-dark/50 text-sm leading-[1.6] mt-5">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut.
          </p>
        </div>
        <div class="px-6 md:px-10 py-6 flex flex-col gap-4 flex-1 border-t border-dark/8">
          {features.map(f => (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0 text-teal" viewBox="0 0 20 20" fill="none">
                <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
                <path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="font-inter text-dark/70 text-xs">{f}</span>
            </div>
          ))}
        </div>
        <div class="p-6 pt-4 md:p-10 md:pt-6">
          <a href="/get-started" class="border border-dark/15 text-dark font-montserrat font-medium text-sm rounded-full py-4 text-center block hover:bg-dark/5 transition-colors">
            Get started
          </a>
        </div>
      </div>

      <!-- Monthly Card — third on both -->
      <div class="bg-cream rounded-2xl flex flex-col order-3">
        <div class="p-6 pb-6 md:p-10 md:pb-8">
          <p class="font-inter text-dark font-semibold text-sm mb-10">
            Monthly
          </p>
          <p class="font-fraunces text-dark text-[48px] leading-none font-bold">
            <span data-price="monthly">$179</span><span class="text-dark/40 text-lg font-normal">/mo</span>
          </p>
          <p class="font-inter text-dark/50 text-sm leading-[1.6] mt-5">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut.
          </p>
        </div>
        <div class="px-6 md:px-10 py-6 flex flex-col gap-4 flex-1 border-t border-dark/8">
          {features.map(f => (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0 text-teal" viewBox="0 0 20 20" fill="none">
                <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
                <path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="font-inter text-dark/70 text-xs">{f}</span>
            </div>
          ))}
        </div>
        <div class="p-6 pt-4 md:p-10 md:pt-6">
          <a href="/get-started" class="border border-dark/15 text-dark font-montserrat font-medium text-sm rounded-full py-4 text-center block hover:bg-dark/5 transition-colors">
            Get started
          </a>
        </div>
      </div>
    </div>
  </div>
  </div>
</section>

<script>
  const pricingData = {
    semaglutide: {
      name: 'Semaglutide',
      monthly: '$179',
      '3mo': '$149',
      '6mo': '$129',
      '3mo_save': 'save 17%',
      '6mo_save': 'save 28%',
    },
    tirzepatide: {
      name: 'Tirzepatide',
      monthly: '$299',
      '3mo': '$249',
      '6mo': '$219',
      '3mo_save': 'save 17%',
      '6mo_save': 'save 27%',
    },
  };

  const section = document.getElementById('weight-pricing');
  const toggleBtns = section.querySelectorAll('.pricing-toggle-btn');
  const drugNameEl = document.getElementById('pricing-drug-name');

  function setDrug(drug) {
    const data = pricingData[drug];
    if (drugNameEl) drugNameEl.textContent = data.name;
    section.querySelectorAll('[data-price]').forEach(el => {
      const key = el.dataset.price;
      if (data[key]) el.textContent = data[key];
    });
    section.querySelectorAll('[data-save]').forEach(el => {
      const key = el.dataset.save + '_save';
      if (data[key]) el.textContent = data[key];
    });
    toggleBtns.forEach(btn => {
      if (btn.dataset.drug === drug) {
        btn.classList.add('bg-cream', 'text-dark');
        btn.classList.remove('text-cream/60');
      } else {
        btn.classList.remove('bg-cream', 'text-dark');
        btn.classList.add('text-cream/60');
      }
    });
  }

  toggleBtns.forEach(btn => {
    btn.addEventListener('click', () => setDrug(btn.dataset.drug));
  });
</script>
