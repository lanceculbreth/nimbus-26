        <button class="pricing-dot w-2 h-2 rounded-full bg-dark/25 transition-all" data-slide="1"></button>
        <button class="pricing-dot w-2 h-2 rounded-full bg-dark/25 transition-all" data-slide="2"></button>
      </div>
    </div>

  </div>
  </div>
