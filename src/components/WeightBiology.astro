---
import photo1 from '../assets/[7] Photography/iStock-1337452483123123 1 (1).png';
import photo2 from '../assets/[7] Photography/iStock-2203624688.jpg';
import photo3 from '../assets/[7] Photography/iStock-2210163746.jpg';
import photo4 from '../assets/[7] Photography/iStock-1276569663.jpg';
import photo5 from '../assets/[7] Photography/iStock-1165116258.jpg';
import photo6 from '../assets/[7] Photography/iStock-1766905173.jpg';

const slides = [
  {
    image: photo1,
    title: 'It\'s biology, not willpower',
    description: 'By moving from shame to understanding, you can finally find the freedom you deserve.',
  },
  {
    image: photo2,
    title: 'Silencing the "food noise"',
    description: 'Our treatments help silence the intrusive thoughts, allowing you to reclaim your focus and your life.',
  },
  {
    image: photo3,
    title: 'The reset',
    description: 'We help you recalibrate your biological settings, so your body can finally find its balance.',
  },
  {
    image: photo4,
    title: 'Starting fresh',
    description: 'Change doesn\'t have to be complicated. Sometimes, it just takes the right guidance and the right tools.',
  },
  {
    image: photo5,
    title: 'Your body, your pace',
    description: 'Every journey is different. We meet you where you are and build a plan that works for your life.',
  },
  {
    image: photo6,
    title: 'Beyond the scale',
    description: 'Real progress isn\'t just a number. It\'s how you feel, how you move, and how you show up every day.',
  },
];
---

<section class="bg-cream py-16 md:py-24 overflow-hidden" data-animate>
  <!-- Header -->
  <div id="bio-header" class="max-w-[1200px] mx-auto px-5 md:px-[10px] mb-10 md:mb-16 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
    <div>
      <p class="font-inter text-terracotta text-base mb-3">Moving from struggle to science.</p>
      <h2 class="font-fraunces text-dark text-[clamp(32px,5vw,72px)] leading-[1.05] tracking-[-0.02em]">
        It's your biology.
      </h2>
    </div>
    <a href="/get-started" class="shrink-0 bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-sm rounded-full px-8 py-4 inline-block transition-colors md:mb-2 w-fit">
      Find your path
    </a>
  </div>

  <!-- Carousel -->
  <div class="relative overflow-hidden">
    <div id="bio-track" class="flex gap-4 md:gap-6 transition-transform duration-500 ease-in-out">
      {slides.map((slide) => (
        <div class="bio-slide shrink-0 w-[calc(100vw-40px)] md:w-[500px]">
          <div class="rounded-2xl overflow-hidden mb-4 md:mb-5">
            <img
              src={slide.image.src}
              alt={slide.title}
              class="w-full h-[350px] md:h-[500px] object-cover"
              loading="lazy"
            />
          </div>
          <h3 class="font-inter text-dark text-base md:text-lg font-bold mb-2 px-1">{slide.title}</h3>
          <p class="font-inter text-dark/60 text-sm leading-[1.6] px-1">{slide.description}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Controls -->
  <div class="flex items-center justify-center gap-6 mt-8">
    <button
      id="bio-prev"
      class="flex items-center justify-center text-dark/40 hover:text-dark transition-colors cursor-pointer"
      aria-label="Previous slide"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Progress bar -->
    <div class="w-20 h-[2px] bg-dark/20 rounded-full overflow-hidden">
      <div id="bio-progress" class="h-full bg-terracotta rounded-full" style="width: 0%"></div>
    </div>

    <button
      id="bio-next"
      class="flex items-center justify-center text-dark/40 hover:text-dark transition-colors cursor-pointer"
      aria-label="Next slide"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

</section>

<script is:inline>
  (function() {
    var track = document.getElementById('bio-track');
    var header = document.getElementById('bio-header');
    var prevBtn = document.getElementById('bio-prev');
    var nextBtn = document.getElementById('bio-next');
    var progress = document.getElementById('bio-progress');
    var current = 0;
    var total = 6;
    var DURATION = 4;

    function getSlideMetrics() {
      var slide = track.querySelector('.bio-slide');
      if (!slide) return { cardWidth: 500, gap: 24 };
      var w = slide.getBoundingClientRect().width;
      var g = parseFloat(getComputedStyle(track).gap) || 24;
      return { cardWidth: w, gap: g };
    }

    function getLeftStart() {
      if (header) {
        var rect = header.getBoundingClientRect();
        var padding = parseFloat(getComputedStyle(header).paddingLeft);
        return rect.left + padding;
      }
      return 20;
    }

    function getOffset(index) {
      var m = getSlideMetrics();
      return -(index * (m.cardWidth + m.gap)) + getLeftStart();
    }

    function startProgress() {
      if (!progress) return;
      progress.style.transition = 'none';
      progress.style.width = '0%';
      progress.getBoundingClientRect();
      progress.style.transition = 'width ' + DURATION + 's linear';
      progress.style.width = '100%';
    }

    function goTo(index) {
      if (index < 0) index = total - 1;
      if (index > total - 1) index = 0;
      current = index;
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
      startProgress();
    }

    progress.addEventListener('transitionend', function(e) {
      if (e.propertyName === 'width' && progress.style.width === '100%') {
        goTo(current + 1);
      }
    });

    track.style.transition = 'none';
    track.style.transform = 'translateX(' + getLeftStart() + 'px)';
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        track.style.transition = '';
      });
    });

    var section = track.closest('section');
    var hasStarted = false;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !hasStarted) {
          hasStarted = true;
          startProgress();
          observer.disconnect();
        }
      });
    }, { threshold: 0.4 });
    if (section) observer.observe(section);

    prevBtn?.addEventListener('click', function() { goTo(current - 1); });
    nextBtn?.addEventListener('click', function() { goTo(current + 1); });

    // Touch swipe
    var touchStartX = 0;
    var touchStartY = 0;
    var touchDeltaX = 0;
    var isSwiping = false;
    var swipeThreshold = 50;

    track.addEventListener('touchstart', function(e) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      touchDeltaX = 0;
      isSwiping = false;
      progress.style.transition = 'none';
      track.style.transition = 'none';
    }, { passive: true });

    track.addEventListener('touchmove', function(e) {
      var dx = e.touches[0].clientX - touchStartX;
      var dy = e.touches[0].clientY - touchStartY;
      if (!isSwiping && Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) {
        isSwiping = true;
      }
      if (isSwiping) {
        e.preventDefault();
        touchDeltaX = dx;
        track.style.transform = 'translateX(' + (getOffset(current) + touchDeltaX) + 'px)';
      }
    }, { passive: false });

    track.addEventListener('touchend', function() {
      track.style.transition = 'transform 0.5s ease-in-out';
      if (isSwiping) {
        if (touchDeltaX < -swipeThreshold) {
          goTo(current + 1);
        } else if (touchDeltaX > swipeThreshold) {
          goTo(current - 1);
        } else {
          track.style.transform = 'translateX(' + getOffset(current) + 'px)';
          startProgress();
        }
      }
      isSwiping = false;
      touchDeltaX = 0;
    }, { passive: true });

    window.addEventListener('resize', function() {
      track.style.transition = 'none';
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          track.style.transition = '';
        });
      });
    });
  })();
</script>
