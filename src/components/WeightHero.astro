---
---

<section class="relative w-full h-[100vh] p-0 md:p-[10px]">
  <!-- Background Video -->
  <div class="absolute inset-0 md:inset-[10px] rounded-none md:rounded-[14px] overflow-hidden">
    <video
      autoplay
      muted
      loop
      playsinline
      class="w-full h-full object-cover"
    >
      <source src="/videos/weight-hero.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-[#1A1816]/50"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-start justify-center h-full px-8 lg:px-16 pt-20 max-w-[1200px] mx-auto w-full">
    <span class="hero-animate font-montserrat text-cream/70 text-sm font-semibold tracking-[0.1em] mb-8 block">
      Weight<strong class="font-bold text-cream">Wise</strong><sup class="text-[9px]">RX</sup> GLP-1 Plan
    </span>

    <span class="hero-animate hero-animate-delay-1 font-fraunces text-cream text-[clamp(48pt,8vw,80pt)] leading-none tracking-[-0.02em] block mb-2">
      Less Noise.
    </span>
    <span class="hero-animate hero-animate-delay-1 font-fraunces text-cream text-[clamp(48pt,8vw,80pt)] leading-none tracking-[-0.02em] block mb-6">
      More Rhythm.
    </span>

    <span class="hero-animate hero-animate-delay-1 font-fraunces text-cream text-2xl mb-8 block">
      $179/mo
    </span>

    <a
      href="/get-started"
      class="hero-animate hero-animate-delay-2 bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-base rounded-full py-4.5 transition-colors max-w-[250px] w-fit px-10 text-center inline-block"
    >
      Find your groove
    </a>
  </div>
</section>
