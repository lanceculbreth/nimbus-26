---
const slides = [
  { image: '/images/Dashboard.png', alt: 'Nimbus patient dashboard — Desktop' },
  { image: '/images/Mobile.png', alt: 'Nimbus patient dashboard — Mobile' },
  { image: '/images/Dashboard.png', alt: 'Nimbus patient dashboard — Desktop' },
  { image: '/images/Mobile.png', alt: 'Nimbus patient dashboard — Mobile' },
  { image: '/images/Dashboard.png', alt: 'Nimbus patient dashboard — Desktop' },
];
---

<section class="py-24 overflow-hidden">
  <!-- Header -->
  <div class="max-w-[1200px] mx-auto px-[10px] text-center mb-16" data-animate>
    <div class="flex items-center justify-center gap-3 mb-4">
      <div class="w-12 h-[2px] bg-teal"></div>
      <span class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase">The Platform</span>
      <div class="w-12 h-[2px] bg-teal"></div>
    </div>
    <h2 class="font-fraunces text-dark text-[clamp(40px,5vw,72px)] leading-[1.05] tracking-[-0.02em]">
      Your care, in one place.
    </h2>
  </div>

  <!-- Centered Carousel -->
  <div class="relative" data-animate data-delay="1">
    <div id="product-carousel" class="overflow-visible">
      <div id="product-track" class="flex gap-5 transition-transform duration-500 ease-in-out">
        {slides.map((slide) => (
          <div class="shrink-0 w-[1200px]">
            <div class="rounded-2xl overflow-hidden">
              <img
                src={slide.image}
                alt={slide.alt}
                class="w-full h-[280px] md:h-[700px] object-cover object-top"
                loading="lazy"
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Controls -->
  <div class="flex items-center justify-center gap-6 mt-8">
    <button
      id="product-prev"
      class="w-11 h-11 rounded-full border border-dark/20 flex items-center justify-center text-dark/40 hover:text-dark hover:border-dark/40 transition-colors cursor-pointer"
      aria-label="Previous slide"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div id="product-dots" class="flex items-center gap-2">
      {slides.map((_, i) => (
        <button
          class="product-dot w-2.5 h-2.5 rounded-full transition-all duration-300 cursor-pointer"
          class:list={[i === 2 ? 'bg-dark' : 'bg-dark/20']}
          data-index={i}
          aria-label={`Go to slide ${i + 1}`}
        />
      ))}
    </div>

    <button
      id="product-next"
      class="w-11 h-11 rounded-full border border-dark/20 flex items-center justify-center text-dark/40 hover:text-dark hover:border-dark/40 transition-colors cursor-pointer"
      aria-label="Next slide"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</section>

<script is:inline>
  (function() {
    var track = document.getElementById('product-track');
    var prevBtn = document.getElementById('product-prev');
    var nextBtn = document.getElementById('product-next');
    var dots = document.querySelectorAll('.product-dot');
    var current = 2; // start on middle card
    var total = dots.length;
    var cardWidth = 1200;
    var gap = 20;

    function getOffset(index) {
      var vw = window.innerWidth;
      // Center the card: shift so card's left edge is at (vw - cardWidth) / 2
      var centerOffset = (vw - cardWidth) / 2;
      return -(index * (cardWidth + gap)) + centerOffset;
    }

    function goTo(index) {
      if (index < 0) index = total - 1;
      if (index > total - 1) index = 0;
      current = index;
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
      dots.forEach(function(dot, i) {
        dot.classList.toggle('bg-dark', i === current);
        dot.classList.toggle('bg-dark/20', i !== current);
      });
    }

    // Set initial position (no transition)
    track.style.transition = 'none';
    track.style.transform = 'translateX(' + getOffset(current) + 'px)';
    // Re-enable transition after paint
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        track.style.transition = '';
      });
    });

    prevBtn?.addEventListener('click', function() { goTo(current - 1); });
    nextBtn?.addEventListener('click', function() { goTo(current + 1); });
    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        goTo(parseInt(dot.dataset.index));
      });
    });

    window.addEventListener('resize', function() {
      track.style.transition = 'none';
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          track.style.transition = '';
        });
      });
    });

    // Auto-advance every 5s
    setInterval(function() { goTo(current + 1); }, 5000);
  })();
</script>
