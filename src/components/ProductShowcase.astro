---
const slides = [
  { image: '/images/platform-1.png', alt: 'Nimbus patient dashboard — Desktop overview' },
  { image: '/images/platform-2.png', alt: 'Nimbus app — Schedule your lab work' },
  { image: '/images/platform-3.png', alt: 'Nimbus app — Lab selection and results flow' },
  { image: '/images/platform-4.png', alt: 'Nimbus app — Lab prep instructions' },
];
---

<section class="py-24 overflow-hidden">
  <!-- Header -->
  <div class="max-w-[1200px] mx-auto px-[10px] text-center mb-16" data-animate>
    <div class="flex items-center justify-center gap-3 mb-4">
      <div class="w-12 h-[2px] bg-teal"></div>
      <span class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase">The Platform</span>
      <div class="w-12 h-[2px] bg-teal"></div>
    </div>
    <h2 class="font-fraunces text-dark text-[clamp(40px,5vw,72px)] leading-[1.05] tracking-[-0.02em]">
      Your care, in one place.
    </h2>
  </div>

  <!-- Centered Carousel -->
  <div class="relative" data-animate data-delay="1">
    <div id="product-carousel" class="overflow-visible">
      <div id="product-track" class="flex gap-5 transition-transform duration-500 ease-in-out">
        {slides.map((slide) => (
          <div class="product-slide shrink-0 w-[calc(100vw-40px)] md:w-[1200px]">
            <div class="rounded-2xl overflow-hidden">
              <img
                src={slide.image}
                alt={slide.alt}
                class="w-full h-[300px] md:h-[700px] object-cover object-top"
                loading="lazy"
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Controls -->
  <div class="flex items-center justify-center gap-4 mt-8">
    <button
      id="product-prev"
      class="w-10 h-10 rounded-full bg-dark/10 flex items-center justify-center text-dark/40 hover:text-dark hover:bg-dark/20 transition-colors cursor-pointer"
      aria-label="Previous slide"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <button
      id="product-next"
      class="w-10 h-10 rounded-full bg-dark/10 flex items-center justify-center text-dark/40 hover:text-dark hover:bg-dark/20 transition-colors cursor-pointer"
      aria-label="Next slide"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</section>

<script is:inline>
  (function() {
    var track = document.getElementById('product-track');
    var prevBtn = document.getElementById('product-prev');
    var nextBtn = document.getElementById('product-next');
    var current = 0;
    var total = 4;

    function getSlideMetrics() {
      var slide = track.querySelector('.product-slide');
      if (!slide) return { cardWidth: 1200, gap: 20 };
      var w = slide.getBoundingClientRect().width;
      var g = parseFloat(getComputedStyle(track).gap) || 20;
      return { cardWidth: w, gap: g };
    }

    function getOffset(index) {
      var m = getSlideMetrics();
      var vw = window.innerWidth;
      var centerOffset = (vw - m.cardWidth) / 2;
      return -(index * (m.cardWidth + m.gap)) + centerOffset;
    }

    function goTo(index) {
      if (index < 0) index = total - 1;
      if (index > total - 1) index = 0;
      current = index;
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
    }

    track.style.transition = 'none';
    track.style.transform = 'translateX(' + getOffset(current) + 'px)';
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        track.style.transition = '';
      });
    });

    prevBtn?.addEventListener('click', function() { goTo(current - 1); });
    nextBtn?.addEventListener('click', function() { goTo(current + 1); });

    // Touch / swipe support
    var touchStartX = 0;
    var touchStartY = 0;
    var touchDeltaX = 0;
    var isSwiping = false;
    var swipeThreshold = 50;

    track.addEventListener('touchstart', function(e) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      touchDeltaX = 0;
      isSwiping = false;
      track.style.transition = 'none';
    }, { passive: true });

    track.addEventListener('touchmove', function(e) {
      var dx = e.touches[0].clientX - touchStartX;
      var dy = e.touches[0].clientY - touchStartY;
      if (!isSwiping && Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) {
        isSwiping = true;
      }
      if (isSwiping) {
        e.preventDefault();
        touchDeltaX = dx;
        track.style.transform = 'translateX(' + (getOffset(current) + touchDeltaX) + 'px)';
      }
    }, { passive: false });

    track.addEventListener('touchend', function() {
      track.style.transition = 'transform 0.5s ease-in-out';
      if (isSwiping) {
        if (touchDeltaX < -swipeThreshold) {
          goTo(current + 1);
        } else if (touchDeltaX > swipeThreshold) {
          goTo(current - 1);
        } else {
          track.style.transform = 'translateX(' + getOffset(current) + 'px)';
        }
      }
      isSwiping = false;
      touchDeltaX = 0;
    }, { passive: true });

    window.addEventListener('resize', function() {
      track.style.transition = 'none';
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          track.style.transition = '';
        });
      });
    });
  })();
</script>
