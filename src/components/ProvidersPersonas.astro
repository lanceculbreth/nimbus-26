---
---

<section class="bg-[#1A1816] py-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-6" data-animate>
      <p class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase mb-4">Built For Your Practice</p>
      <h2 class="font-fraunces text-cream text-[clamp(36px,5vw,64px)] leading-[1.08] tracking-[-0.02em]">
        One platform. Every<br />
        <em class="italic text-teal">clinic type.</em>
      </h2>
    </div>

    <div class="text-center max-w-[560px] mx-auto mb-16" data-animate data-delay="1">
      <p class="font-inter text-cream/50 text-base leading-[1.6]">
        Whether you're running a solo med spa or a multi-state network, NovaMed adapts to your workflow — not the other way around.
      </p>
    </div>

    <!-- Persona Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-stagger>
      <!-- Aesthetic & Longevity -->
      <div class="bg-[#22201E] rounded-2xl p-8 border border-cream/5 hover-lift">
        <div class="w-12 h-12 rounded-full bg-teal/10 flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
          </svg>
        </div>
        <h3 class="font-fraunces text-cream text-2xl mb-4">
          Aesthetic & Longevity Clinics
        </h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="text-teal mt-1 text-sm">→</span>
            <span class="font-inter text-cream/50 text-sm leading-[1.6]">Weight loss, peptide, and hormone protocol management with automated dosing schedules</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-teal mt-1 text-sm">→</span>
            <span class="font-inter text-cream/50 text-sm leading-[1.6]">Real-time compound pricing across formulations — choose the best option for your patient's budget</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-teal mt-1 text-sm">→</span>
            <span class="font-inter text-cream/50 text-sm leading-[1.6]">Automated refill cycles that drive adherence and recurring revenue without manual outreach</span>
          </li>
        </ul>
      </div>

      <!-- Functional & Integrative -->
      <div class="bg-[#22201E] rounded-2xl p-8 border border-cream/5 hover-lift">
        <div class="w-12 h-12 rounded-full bg-teal/10 flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
        </div>
        <h3 class="font-fraunces text-cream text-2xl mb-4">
          Functional & Integrative Medicine
        </h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="text-teal mt-1 text-sm">→</span>
            <span class="font-inter text-cream/50 text-sm leading-[1.6]">Complex multi-step protocol timelines with conditional logic and milestone tracking</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-teal mt-1 text-sm">→</span>
            <span class="font-inter text-cream/50 text-sm leading-[1.6]">Lab result integration with longitudinal biomarker trending to validate treatment efficacy</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-teal mt-1 text-sm">→</span>
            <span class="font-inter text-cream/50 text-sm leading-[1.6]">Collaborative care workflows connecting prescribers, coaches, nutritionists, and PTs</span>
          </li>
        </ul>
      </div>

      <!-- Multi-Location Networks -->
      <div class="bg-[#22201E] rounded-2xl p-8 border border-cream/5 hover-lift">
        <div class="w-12 h-12 rounded-full bg-teal/10 flex items-center justify-center mb-6">
          <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />
          </svg>
        </div>
        <h3 class="font-fraunces text-cream text-2xl mb-4">
          Multi-Location Networks
        </h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="text-teal mt-1 text-sm">→</span>
            <span class="font-inter text-cream/50 text-sm leading-[1.6]">Centralized protocol management across locations with per-site customization and role-based access</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-teal mt-1 text-sm">→</span>
            <span class="font-inter text-cream/50 text-sm leading-[1.6]">Network-wide analytics: prescription volume, revenue per location, provider utilization, and fulfillment velocity</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-teal mt-1 text-sm">→</span>
            <span class="font-inter text-cream/50 text-sm leading-[1.6]">Enterprise billing with consolidated invoicing, automated pharmacy payables, and commission tracking</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
