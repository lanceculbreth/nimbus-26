---
// Image served from public/images/snap food hero.png

const features = [
  {
    title: 'Improved Adherence & Persistence',
    description: 'Integrated clinical management keeps employees on track throughout their journey.',
  },
  {
    title: 'Reduced Side Effects & Discontinuation',
    description: 'Clinician-managed dosing and nutrition support minimize the friction that causes drop-off.',
  },
  {
    title: 'Independent Clinical Decisions',
    description: 'Care decisions are made on clinical merit, free from financial incentives or formulary pressure.',
  },
  {
    title: 'Flat, Predictable Employer Cost',
    description: 'One rate covers any drug, any dose, any clinical adjustment, no surprises.',
  },
];
---

<section class="bg-cream pt-24 pb-10 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Top: Heading + Subtitle + CTA -->
    <div class="text-center mb-12" data-animate>
      <div class="flex items-center justify-center gap-3 mb-4">
        <div class="w-12 h-[2px] bg-teal"></div>
        <span class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase">Nutrition</span>
        <div class="w-12 h-[2px] bg-teal"></div>
      </div>

      <h2 class="font-fraunces text-dark text-[clamp(40px,5vw,72px)] leading-[1.05] tracking-[-0.02em] mb-6">
        Food for <em class="text-terracotta not-italic italic">GLP-1s.</em>
      </h2>

      <p class="font-inter text-dark/70 text-base leading-[1.6] max-w-[550px] mx-auto mb-8">
        Nutrition designed to complement your GLP-1 therapy. Meals that support your metabolism, reduce side effects, and keep results lasting.
      </p>

      <a href="/get-started" class="inline-block bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-sm rounded-full px-8 py-4 transition-colors">
        Find your path
      </a>
    </div>

    <!-- Food Image -->
    <div class="mb-16" data-animate="scale-in">
      <img
        src="/images/snap food hero.png"
        alt="Grilled steak bowl meal prep with roasted sweet potato, black beans, chimichurri, and fresh herbs"
        class="w-full rounded-2xl object-cover aspect-[16/9]"
      />
    </div>

    <!-- Partnership: Snap Kitchen -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 mb-16 border border-dark/10 rounded-2xl px-8 py-6" data-animate>
      <div class="shrink-0">
        <img
          src="/images/snap-kitchen-logo.png"
          alt="Snap Kitchen"
          class="h-8 w-auto object-contain"
        />
      </div>
      <div class="hidden sm:block w-px h-8 bg-dark/15 shrink-0"></div>
      <p class="font-inter text-dark/60 text-sm leading-[1.6] flex-1">
        Nimbus has partnered with Snap Kitchen to deliver chef-prepared, GLP-1 optimized meals — designed to reduce side effects, support protein intake, and keep results lasting.
      </p>
      <a
        href="https://meals.nimbushealthcare.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 inline-block bg-dark hover:bg-dark/80 text-cream font-montserrat font-medium text-sm rounded-full px-6 py-3 transition-colors whitespace-nowrap"
      >
        Order meals
      </a>
    </div>

    <!-- Bottom: Statement + Feature Grid -->
    <div>
      <h3 class="font-fraunces text-dark text-[clamp(28px,3.2vw,42px)] leading-[1.2] tracking-[-0.02em] mb-12 max-w-[600px]" data-animate>
        Medication initiates the signal.<br />
        Food makes it <span class="text-teal">sustainable.</span>
      </h3>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8" data-stagger>
        {features.map(feature => (
          <div class="border-t-2 border-teal/20 pt-6">
            <h4 class="font-inter text-dark text-base font-bold leading-[1.3] mb-3">
              {feature.title}
            </h4>
            <p class="font-inter text-dark/60 text-sm leading-[1.6]">
              {feature.description}
            </p>
          </div>
        ))}
      </div>

      <!-- Food Video -->
      <div class="mt-16 relative overflow-hidden rounded-2xl" data-animate="scale-in">
        <video
          id="food-video"
          autoplay
          muted
          loop
          playsinline
          class="w-full object-cover aspect-[16/9]"
          poster="/images/snap food hero.png"
        >
          <source src="/videos/snapk-hero.mp4" type="video/mp4" />
        </video>

        <!-- Controls -->
        <div class="absolute bottom-5 left-5 flex items-center gap-3">
          <!-- Restart Button -->
          <button
            id="food-restart"
            class="w-10 h-10 rounded-full bg-dark/60 backdrop-blur-sm flex items-center justify-center hover:bg-dark/80 transition-colors cursor-pointer"
            aria-label="Restart video"
          >
            <svg class="w-4.5 h-4.5 text-cream" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
            </svg>
          </button>

          <!-- Play/Pause Button -->
          <button
            id="food-play-pause"
            class="w-10 h-10 rounded-full bg-dark/60 backdrop-blur-sm flex items-center justify-center hover:bg-dark/80 transition-colors cursor-pointer"
            aria-label="Pause video"
          >
            <svg id="food-pause-icon" class="w-5 h-5 text-cream" viewBox="0 0 20 20" fill="currentColor">
              <path d="M5 4h3v12H5V4zm7 0h3v12h-3V4z"/>
            </svg>
            <svg id="food-play-icon" class="w-5 h-5 text-cream hidden" viewBox="0 0 20 20" fill="currentColor">
              <path d="M6 4l10 6-10 6V4z"/>
            </svg>
          </button>

          <!-- Mute/Unmute Button -->
          <button
            id="food-mute"
            class="w-10 h-10 rounded-full bg-dark/60 backdrop-blur-sm flex items-center justify-center hover:bg-dark/80 transition-colors cursor-pointer"
            aria-label="Unmute video"
          >
            <svg id="food-muted-icon" class="w-5 h-5 text-cream" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
              <line x1="23" y1="9" x2="17" y2="15"/>
              <line x1="17" y1="9" x2="23" y2="15"/>
            </svg>
            <svg id="food-unmuted-icon" class="w-5 h-5 text-cream hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
              <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const foodVideo = document.getElementById('food-video') as HTMLVideoElement;
  const foodPlayPauseBtn = document.getElementById('food-play-pause');
  const foodPauseIcon = document.getElementById('food-pause-icon');
  const foodPlayIcon = document.getElementById('food-play-icon');
  const foodRestartBtn = document.getElementById('food-restart');
  const foodMuteBtn = document.getElementById('food-mute');
  const foodMutedIcon = document.getElementById('food-muted-icon');
  const foodUnmutedIcon = document.getElementById('food-unmuted-icon');

  foodPlayPauseBtn?.addEventListener('click', () => {
    if (foodVideo.paused) {
      foodVideo.play();
      foodPauseIcon?.classList.remove('hidden');
      foodPlayIcon?.classList.add('hidden');
      foodPlayPauseBtn.setAttribute('aria-label', 'Pause video');
    } else {
      foodVideo.pause();
      foodPauseIcon?.classList.add('hidden');
      foodPlayIcon?.classList.remove('hidden');
      foodPlayPauseBtn.setAttribute('aria-label', 'Play video');
    }
  });

  foodRestartBtn?.addEventListener('click', () => {
    foodVideo.currentTime = 0;
    foodVideo.play();
    foodPauseIcon?.classList.remove('hidden');
    foodPlayIcon?.classList.add('hidden');
    foodPlayPauseBtn?.setAttribute('aria-label', 'Pause video');
  });

  foodMuteBtn?.addEventListener('click', () => {
    foodVideo.muted = !foodVideo.muted;
    if (foodVideo.muted) {
      foodMutedIcon?.classList.remove('hidden');
      foodUnmutedIcon?.classList.add('hidden');
      foodMuteBtn.setAttribute('aria-label', 'Unmute video');
    } else {
      foodMutedIcon?.classList.add('hidden');
      foodUnmutedIcon?.classList.remove('hidden');
      foodMuteBtn.setAttribute('aria-label', 'Mute video');
    }
  });
</script>
