---
---

<section class="bg-[#1A1816] py-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-20" data-animate>
      <p class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase mb-4">Clinical Credibility</p>
      <h2 class="font-fraunces text-cream text-[clamp(36px,5vw,64px)] leading-[1.08] tracking-[-0.02em]">
        Led by clinicians.<br />
        <em class="italic text-teal">Built on trust.</em>
      </h2>
    </div>

    <!-- Medical Board -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-20" data-stagger>
      <div class="text-center">
        <div class="w-20 h-20 rounded-full bg-[#22201E] border border-cream/10 mx-auto mb-4 flex items-center justify-center">
          <span class="font-fraunces text-cream/60 text-2xl">JJ</span>
        </div>
        <p class="font-inter text-cream font-semibold text-sm">Dr. Jobby John</p>
        <p class="font-inter text-cream/40 text-xs">PharmD, FACA · CEO & Founder</p>
        <p class="font-inter text-teal/60 text-[10px] mt-1">Past President, TX Pharmacy Assoc.</p>
      </div>

      <div class="text-center">
        <div class="w-20 h-20 rounded-full bg-[#22201E] border border-cream/10 mx-auto mb-4 flex items-center justify-center">
          <span class="font-fraunces text-cream/60 text-2xl">DH</span>
        </div>
        <p class="font-inter text-cream font-semibold text-sm">Dr. Harris</p>
        <p class="font-inter text-cream/40 text-xs">Chief Medical Officer</p>
      </div>

      <div class="text-center">
        <div class="w-20 h-20 rounded-full bg-[#22201E] border border-cream/10 mx-auto mb-4 flex items-center justify-center">
          <span class="font-fraunces text-cream/60 text-2xl">DN</span>
        </div>
        <p class="font-inter text-cream font-semibold text-sm">Dr. Neal</p>
        <p class="font-inter text-cream/40 text-xs">Women's Health</p>
      </div>

      <div class="text-center">
        <div class="w-20 h-20 rounded-full bg-[#22201E] border border-cream/10 mx-auto mb-4 flex items-center justify-center">
          <span class="font-fraunces text-cream/60 text-2xl">DT</span>
        </div>
        <p class="font-inter text-cream font-semibold text-sm">Dr. Thoppil</p>
        <p class="font-inter text-cream/40 text-xs">OB-GYN</p>
      </div>
    </div>

    <!-- Trust Stats Bar -->
    <div class="bg-[#22201E] rounded-3xl p-10 md:p-14" data-animate>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <p class="font-fraunces text-cream text-[clamp(32px,4vw,48px)] leading-none mb-2">1,200+</p>
          <p class="font-inter text-cream/40 text-sm">Active Patients</p>
        </div>
        <div>
          <p class="font-fraunces text-cream text-[clamp(32px,4vw,48px)] leading-none mb-2">116+</p>
          <p class="font-inter text-cream/40 text-sm">Partner Clinics</p>
        </div>
        <div>
          <p class="font-fraunces text-cream text-[clamp(32px,4vw,48px)] leading-none mb-2">37</p>
          <p class="font-inter text-cream/40 text-sm">State Licenses</p>
        </div>
        <div>
          <p class="font-fraunces text-cream text-[clamp(32px,4vw,48px)] leading-none mb-2">$1M+</p>
          <p class="font-inter text-cream/40 text-sm">Monthly Pharmacy Volume</p>
        </div>
      </div>
    </div>

    <!-- Pharmacy Backing -->
    <div class="text-center mt-10" data-animate>
      <p class="font-inter text-cream/30 text-sm">
        Backed by <span class="text-cream/60 font-medium">Lake Hills Pharmacy</span> — a fully licensed, NABP-accredited compounding pharmacy in Austin, TX
      </p>
    </div>
  </div>
</section>
