---
const steps = [
  {
    number: '01',
    title: 'Complete Your Intake',
    description: 'Share your symptoms, goals, and medical history through our secure online assessment.',
  },
  {
    number: '02',
    title: 'Get Comprehensive Labs',
    description: 'A full 70+ biomarker panel at a nearby lab or via at-home blood draw — everything your provider needs.',
  },
  {
    number: '03',
    title: 'Meet Your Clinician',
    description: 'A licensed specialist explains your results in plain language and builds your personalized plan via video.',
  },
  {
    number: '04',
    title: 'Start Treatment',
    description: 'Custom-compounded medications ship to your door with clear dosing guidance and quality reports.',
  },
  {
    number: '05',
    title: 'Optimize Continuously',
    description: 'Repeat labs at 90 days and annually. Aura™ wearable data helps your clinician make smarter adjustments.',
  },
];
---

<section class="pt-24 pb-20" data-animate>
  <!-- Header -->
  <div id="steps-header" class="max-w-[1200px] mx-auto px-4 md:px-[10px] mb-10">
    <div class="flex items-end justify-between">
      <div>
        <p class="font-inter text-teal text-base mb-3">How it works</p>
        <h2 class="font-fraunces text-cream text-[clamp(40px,5vw,72px)] leading-[1.05] tracking-[-0.02em]">
          Five steps to a <span class="text-teal">better</span> you.
        </h2>
      </div>
      <!-- Arrow Buttons -->
      <div class="flex items-center gap-2 pb-2">
        <button
          id="steps-prev"
          class="w-11 h-11 rounded-full border border-cream/20 flex items-center justify-center text-cream/40 hover:text-cream hover:border-cream/40 transition-colors cursor-pointer"
          aria-label="Previous slide"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          id="steps-next"
          class="w-11 h-11 rounded-full border border-cream/20 flex items-center justify-center text-cream/40 hover:text-cream hover:border-cream/40 transition-colors cursor-pointer"
          aria-label="Next slide"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Carousel (bleeds right) -->
  <div
    id="steps-carousel"
    class="flex gap-6 overflow-x-auto snap-x snap-mandatory pb-4"
    style="scrollbar-width: none;"
  >
    <!-- Leading spacer to align first card with header -->
    <div id="steps-spacer" class="shrink-0" aria-hidden="true"></div>
    {steps.map((step, i) => (
      <div class="snap-start shrink-0 w-[400px]">
        <!-- Card with number -->
        <div class="bg-[#22201E] rounded-2xl h-[420px] flex flex-col justify-end p-8 mb-5">
          <span class="font-fraunces text-teal/60 text-[100px] leading-none tracking-[-0.04em]">
            {step.number}
          </span>
        </div>
        <h3 class="font-inter text-cream text-lg font-bold mb-2 px-5">{step.title}</h3>
        <p class="font-inter text-cream/40 text-sm leading-[1.6] px-5">{step.description}</p>
      </div>
    ))}
    <!-- Trailing spacer to bleed last card off-screen -->
    <div class="shrink-0 w-[1px]" aria-hidden="true"></div>
  </div>
</section>

<style>
  #steps-carousel::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const carousel = document.getElementById('steps-carousel');
  const header = document.getElementById('steps-header');
  const prevBtn = document.getElementById('steps-prev');
  const nextBtn = document.getElementById('steps-next');
  const cardWidth = 400 + 24; // card width + gap

  function alignStepsCarousel() {
    if (header && carousel) {
      const rect = header.getBoundingClientRect();
      const padding = parseFloat(getComputedStyle(header).paddingLeft);
      carousel.style.paddingLeft = (rect.left + padding) + 'px';
    }
  }

  alignStepsCarousel();
  window.addEventListener('resize', alignStepsCarousel);

  prevBtn?.addEventListener('click', () => {
    carousel?.scrollBy({ left: -cardWidth, behavior: 'smooth' });
  });

  nextBtn?.addEventListener('click', () => {
    carousel?.scrollBy({ left: cardWidth, behavior: 'smooth' });
  });
</script>
