---
import familyImg from '../assets/[4] Product Imagery & Video/iStock-2187968525.jpg';
import womanImg from '../assets/[4] Product Imagery & Video/iStock-2203624688.jpg';
---

<section class="pt-20 pb-20 px-[10px]">
  <div class="max-w-[1200px] mx-auto">

      <!-- Header -->
      <div class="text-center mb-16" data-animate>
        <h2 class="font-fraunces text-cream text-[clamp(36px,5vw,72px)] leading-[1.1] tracking-[-0.02em] mb-6">
          Healthcare that actually<br /><span class="text-teal">connects</span> the dots.
        </h2>
        <p class="font-inter text-cream/40 text-base leading-[1.7] max-w-[580px] mx-auto">
          Most healthcare is reactive and fragmented. NimCore® brings diagnostics, clinical care, and pharmacy together into one seamless, personalized experience. You deserve answers, not guesswork.
        </p>
      </div>

      <!-- Two-Column Photos -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-10" data-animate data-delay="1">
        <!-- Left Photo — Family -->
        <div class="rounded-xl overflow-hidden hover-zoom">
          <img
            src={familyImg.src}
            alt="Family enjoying time together"
            class="w-full h-[400px] md:h-[500px] object-cover"
          />
        </div>

        <!-- Right Photo — Woman -->
        <div class="rounded-xl overflow-hidden hover-zoom">
          <img
            src={womanImg.src}
            alt="Woman feeling vibrant and healthy"
            class="w-full h-[400px] md:h-[500px] object-cover"
          />
        </div>
      </div>

      <!-- Two-Column Descriptions -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5" data-animate data-delay="2">
        <!-- Left Description -->
        <div class="px-4 md:px-6">
          <h3 class="font-fraunces text-cream text-xl leading-[1.3] tracking-[-0.01em] mb-3">
            Data-Driven Diagnostics & Care
          </h3>
          <p class="font-inter text-cream/40 text-sm leading-[1.7]">
            Combine baseline lab panels tracking 70+ biomarkers with specialist providers focused on metabolic health. Move beyond symptom-guessing with continuous optimization that syncs wearable data to your clinical results.
          </p>
        </div>

        <!-- Right Description -->
        <div class="px-4 md:px-6">
          <h3 class="font-fraunces text-cream text-xl leading-[1.3] tracking-[-0.01em] mb-3">
            Integrated Pharmacy & Protocols
          </h3>
          <p class="font-inter text-cream/40 text-sm leading-[1.7]">
            Access custom-compounded medications via our NABP-accredited pharmacy with member-subsidized pricing. Enjoy full transparency and seamless delivery without hidden markups or rushed, 15-minute consultations.
          </p>
        </div>
      </div>

  </div>
</section>
