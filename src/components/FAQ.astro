---
const faqs = [
  {
    question: 'What is Nimbus Healthcare?',
    answer: `<p>Nimbus Healthcare is a modern, personalized wellness platform that offers treatment programs for hormone optimization, weight loss, hair restoration, and more. Unlike other services, we manage your entire care journey in-house from consultation through medication delivery.</p>
<p>Your treatment is guided by real-time data and continuous provider support, allowing us to make ongoing adjustments tailored to how you respond.</p>
<p>All medications are custom-compounded at our pharmacy, ensuring consistent quality and a seamless experience from start to finish.</p>`,
  },
  {
    question: 'Where is Nimbus currently available, and do you ship medications?',
    answer: `<p>Nimbus is currently available in the following states: Alabama, Arizona, Arkansas, Colorado, District of Columbia (Washington DC), Florida, Georgia, Hawaii, Idaho, Illinois, Indiana, Iowa, Kansas, Louisiana, Maine, Maryland, Michigan, Mississippi, Missouri, Montana, Nebraska, Nevada, New Hampshire, New Jersey, New York, North Dakota, Ohio, Oklahoma, Oregon, Pennsylvania, South Dakota, Tennessee, Texas, Washington, West Virginia, Wisconsin, and Wyoming.</p>
<p>We are regularly adding more state licenses, so if there is somewhere you'd like to see us add next, feel free to let us know!</p>
<p>Once prescribed, your medication is delivered directly to your door with clear, step-by-step instructions to help you get started confidently.</p>`,
  },
  {
    question: 'Are Nimbus services covered by health insurance?',
    answer: `<p>Most products and services offered by Nimbus are eligible for payment through FSA (Flexible Spending Account) or HSA (Health Savings Account). While Nimbus Healthcare services are not typically covered by insurance, patients can submit receipts to their insurance company for potential reimbursement, depending on their policy and procedures.</p>
<p>We recommend contacting your insurance provider for specific details about reimbursement and coverage options. Nimbus is not able to fill out forms or provide additional letters of documentation from our doctor for your HSA/FSA.</p>`,
  },
  {
    question: 'How do I get started as a patient?',
    answer: `<ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:1rem;">
<li><strong>Complete a Health Assessment:</strong> Select the plan that you are interested in on our website, register for the program and we'll be in touch with next steps. Whether that's an at home test kit, lab services or an asynchronous provider visit, we're here to support you every step of the way.</li>
<li><strong>Connect with a Provider:</strong> After submitting your assessment, you'll have an asynchronous virtual consultation with a licensed healthcare provider who will determine if treatment is appropriate for you. Please note: Lab testing may be required for certain programs prior to your consultation.</li>
<li><strong>Receive Treatment:</strong> Your medication will be conveniently shipped directly to your door with detailed guidance.</li>
<li><strong>Ongoing Check-ins:</strong> You'll have regular virtual check-ins and access to your patient portal for continued support and progress tracking.</li>
</ul>`,
  },
  {
    question: 'What do I do in case of a health emergency?',
    answer: `<p>Nimbus providers and services are not intended to handle medical emergencies. If you're experiencing symptoms of a medical emergency, please call 911, contact your primary care provider or visit your nearest urgent care center.</p>`,
  },
];
---

<section class="bg-cream py-24 px-[10px]">
  <div class="max-w-[900px] mx-auto">
    <!-- Heading -->
    <div class="flex items-center gap-3 mb-4" data-animate>
      <span class="font-montserrat text-teal text-sm font-semibold tracking-[0.15em] uppercase">Support</span>
      <div class="w-12 h-[2px] bg-teal"></div>
    </div>
    <h2 class="font-fraunces text-dark text-[clamp(56px,6vw,96px)] leading-[1] tracking-[-0.02em] mb-16" data-animate data-delay="1">
      FAQ
    </h2>

    <!-- Accordion -->
    <div class="faq-list" data-animate data-delay="2">
      {faqs.map((faq, i) => (
        <div class="faq-item border-b border-dark/10" data-faq-index={i}>
          <button
            class="faq-toggle w-full flex items-center justify-between py-6 text-left cursor-pointer group"
            aria-expanded={i === 0 ? 'true' : 'false'}
          >
            <span class="font-inter text-dark text-lg leading-[1.4] pr-8">
              {faq.question}
            </span>
            <span class="faq-icon shrink-0 w-6 h-6 flex items-center justify-center text-teal text-xl font-light transition-transform duration-300">
              {i === 0 ? '−' : '+'}
            </span>
          </button>
          <div
            class:list={[
              'faq-content overflow-hidden transition-all duration-400 ease-out',
              i === 0 ? 'max-h-[600px] opacity-100' : 'max-h-0 opacity-0',
            ]}
          >
            <div class="pb-8 font-inter text-dark/70 text-base leading-[1.7] space-y-4 max-w-[800px]" set:html={faq.answer} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const items = document.querySelectorAll('.faq-item');

  items.forEach((item) => {
    const toggle = item.querySelector('.faq-toggle');
    const content = item.querySelector('.faq-content') as HTMLElement;
    const icon = item.querySelector('.faq-icon');

    toggle?.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';

      // Close all
      items.forEach((other) => {
        const otherToggle = other.querySelector('.faq-toggle');
        const otherContent = other.querySelector('.faq-content') as HTMLElement;
        const otherIcon = other.querySelector('.faq-icon');
        otherToggle?.setAttribute('aria-expanded', 'false');
        if (otherContent) {
          otherContent.style.maxHeight = '0px';
          otherContent.style.opacity = '0';
        }
        if (otherIcon) otherIcon.textContent = '+';
      });

      // Open clicked (if it was closed)
      if (!isOpen) {
        toggle.setAttribute('aria-expanded', 'true');
        if (content) {
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.opacity = '1';
        }
        if (icon) icon.textContent = '−';
      }
    });
  });
</script>

<style>
  .faq-content {
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.3s ease;
  }
</style>
