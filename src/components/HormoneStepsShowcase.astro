---
const steps = [
  {
    number: '01',
    title: 'Complete Your Intake',
    description: 'Share your symptoms, goals, and medical history through our secure online assessment.',
    image: '/images/hormone-step-01.png',
  },
  {
    number: '02',
    title: 'Get Comprehensive Labs',
    description: 'A full 70+ biomarker panel at a nearby lab or via at-home blood draw — everything your provider needs.',
    image: '/images/hormone-step-02.png',
  },
  {
    number: '03',
    title: 'Meet Your Clinician',
    description: 'A licensed specialist explains your results in plain language and builds your personalized plan via video.',
    video: '/videos/meet-clinician.mp4',
  },
  {
    number: '04',
    title: 'Start Treatment',
    description: 'Custom-compounded medications ship to your door with clear dosing guidance and quality reports.',
    image: '/images/Start Treatment.jpg',
  },
  {
    number: '05',
    title: 'Optimize Continuously',
    description: 'Repeat labs at 90 days and annually. Aura™ wearable data helps your clinician make smarter adjustments.',
    image: '/images/Optimized.jpg',
  },
];
---

<section class="py-16 md:py-24 overflow-hidden">
  <!-- Header -->
  <div id="hormone-showcase-header" class="max-w-[1200px] mx-auto px-5 md:px-[10px] mb-10 md:mb-16" data-animate>
    <p class="font-inter text-teal text-base mb-3">How it works</p>
    <h2 class="font-fraunces text-cream text-[clamp(32px,5vw,72px)] leading-[1.05] tracking-[-0.02em]">
      Five steps to a <span class="text-teal">better</span> you.
    </h2>
  </div>

  <!-- Carousel -->
  <div class="relative" data-animate data-delay="1">
    <div id="hormone-showcase-carousel" class="overflow-visible">
      <div id="hormone-showcase-track" class="flex gap-4 md:gap-5 transition-transform duration-500 ease-in-out">
        {steps.map((step) => (
          <div class="hormone-showcase-slide shrink-0 w-[calc(100vw-40px)] md:w-[700px]">
            {step.video ? (
              <div class="relative rounded-2xl h-[380px] md:h-[480px] overflow-hidden mb-4 md:mb-5">
                <video
                  src={step.video}
                  class="w-full h-full object-cover"
                  autoplay
                  muted
                  loop
                  playsinline
                />
              </div>
            ) : step.image ? (
              <div class="relative rounded-2xl h-[380px] md:h-[480px] overflow-hidden mb-4 md:mb-5">
                <img src={step.image} alt={step.title} class="w-full h-full object-cover object-top" />
                <div class="absolute inset-0 bg-dark/20"></div>
              </div>
            ) : (
              <div class="rounded-2xl bg-[#22201E] h-[380px] md:h-[480px] mb-4 md:mb-5"></div>
            )}
            <div class="max-w-[500px] px-6 md:px-8">
              <h3 class="font-inter text-cream text-base md:text-lg font-bold mb-2">{step.number}. {step.title}</h3>
              <p class="font-inter text-cream/40 text-sm leading-[1.6]">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Controls -->
  <div class="flex items-center justify-end gap-4 mt-8 max-w-[1200px] mx-auto px-5 md:px-[10px]">
    <button
      id="hormone-showcase-prev"
      class="w-10 h-10 rounded-full bg-cream/10 flex items-center justify-center text-cream/40 hover:text-cream hover:bg-cream/20 transition-colors cursor-pointer"
      aria-label="Previous slide"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <button
      id="hormone-showcase-next"
      class="w-10 h-10 rounded-full bg-cream/10 flex items-center justify-center text-cream/40 hover:text-cream hover:bg-cream/20 transition-colors cursor-pointer"
      aria-label="Next slide"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</section>

<script is:inline>
  (function() {
    var track = document.getElementById('hormone-showcase-track');
    var header = document.getElementById('hormone-showcase-header');
    var prevBtn = document.getElementById('hormone-showcase-prev');
    var nextBtn = document.getElementById('hormone-showcase-next');
    var current = 0;
    var total = 5;

    function getSlideMetrics() {
      var slide = track.querySelector('.hormone-showcase-slide');
      if (!slide) return { cardWidth: 700, gap: 20 };
      var w = slide.getBoundingClientRect().width;
      var g = parseFloat(getComputedStyle(track).gap) || 20;
      return { cardWidth: w, gap: g };
    }

    function getLeftStart() {
      if (header) {
        var rect = header.getBoundingClientRect();
        var padding = parseFloat(getComputedStyle(header).paddingLeft);
        return rect.left + padding;
      }
      return 20;
    }

    function getOffset(index) {
      var m = getSlideMetrics();
      return -(index * (m.cardWidth + m.gap)) + getLeftStart();
    }

    function goTo(index) {
      if (index < 0) index = total - 1;
      if (index > total - 1) index = 0;
      current = index;
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
    }

    // Set initial position (no transition)
    track.style.transition = 'none';
    track.style.transform = 'translateX(' + getOffset(current) + 'px)';
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        track.style.transition = '';
      });
    });

    prevBtn?.addEventListener('click', function() { goTo(current - 1); });
    nextBtn?.addEventListener('click', function() { goTo(current + 1); });

    // Touch / swipe support
    var touchStartX = 0;
    var touchStartY = 0;
    var touchDeltaX = 0;
    var isSwiping = false;
    var swipeThreshold = 50;

    track.addEventListener('touchstart', function(e) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      touchDeltaX = 0;
      isSwiping = false;
      track.style.transition = 'none';
    }, { passive: true });

    track.addEventListener('touchmove', function(e) {
      var dx = e.touches[0].clientX - touchStartX;
      var dy = e.touches[0].clientY - touchStartY;
      if (!isSwiping && Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) {
        isSwiping = true;
      }
      if (isSwiping) {
        e.preventDefault();
        touchDeltaX = dx;
        track.style.transform = 'translateX(' + (getOffset(current) + touchDeltaX) + 'px)';
      }
    }, { passive: false });

    track.addEventListener('touchend', function() {
      track.style.transition = 'transform 0.5s ease-in-out';
      if (isSwiping) {
        if (touchDeltaX < -swipeThreshold) {
          goTo(current + 1);
        } else if (touchDeltaX > swipeThreshold) {
          goTo(current - 1);
        } else {
          track.style.transform = 'translateX(' + getOffset(current) + 'px)';
        }
      }
      isSwiping = false;
      touchDeltaX = 0;
    }, { passive: true });

    window.addEventListener('resize', function() {
      track.style.transition = 'none';
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          track.style.transition = '';
        });
      });
    });
  })();
</script>
