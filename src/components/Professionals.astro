---
import jobbyImg from '../assets/[9] Headshots/Dr Jobby John.png';
import richardImg from '../assets/[9] Headshots/Dr Richard Harris.png';
import tracyImg from '../assets/[9] Headshots/Dr Tracy Neal.png';
import thoppilImg from '../assets/[9] Headshots/Dr John Thoppil.png';

const providers = [
  {
    name: 'Dr. Jobby John',
    title: 'Founder & CEO',
    image: jobbyImg,
    href: '/dr-john',
  },
  {
    name: 'Dr. Richard Harris',
    title: 'Chief Medical Officer',
    image: richardImg,
  },
  {
    name: 'Dr. Tracy Neal',
    title: "Director, Women's Health Division",
    image: tracyImg,
  },
  {
    name: 'Dr. John Thoppil',
    title: 'MD – Board-Certified OB-GYN',
    image: thoppilImg,
  },
];
---

<section class="bg-cream py-24 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Header -->
    <div class="text-center mb-16" data-animate>
      <h2 class="font-fraunces text-dark text-[clamp(40px,6vw,80px)] leading-[1.05] tracking-[-0.02em] mb-4">
        World-class professionals.
      </h2>
      <p class="font-inter text-dark/50 text-base leading-[1.6]">
        Board-certified clinicians, not algorithmic approvals.
      </p>
    </div>

    <!-- Provider Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-14" data-animate data-delay="1">
      {providers.map(provider => (
        <div>
          <div class="bg-[#EAE4DD] rounded-2xl overflow-hidden aspect-square mb-4">
            <img
              src={provider.image.src}
              alt={provider.name}
              class="w-full h-full object-cover object-top"
            />
          </div>
          <h3 class="font-inter text-dark text-lg font-semibold leading-[1.3]">{provider.name}</h3>
          <p class="font-inter text-dark/50 text-sm leading-[1.5]">{provider.title}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center" data-animate data-delay="2">
      <a
        href="/get-started"
        class="inline-block bg-terracotta hover:bg-terracotta-hover text-cream font-montserrat font-medium text-sm rounded-full px-10 py-4.5 transition-colors"
      >
        Find your path
      </a>
    </div>
  </div>
</section>
