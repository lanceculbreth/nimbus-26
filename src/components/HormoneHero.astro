---
import dashboardImg from '../assets/[4] Product Imagery & Video/Platform 1.png';
---

<section class="bg-[#1A1816] pt-52 pb-20 px-[10px]">
  <div class="max-w-[1200px] mx-auto">
    <!-- Headline -->
    <div class="text-left md:text-center mb-8" data-animate>
      <h1 class="font-fraunces text-cream text-[clamp(48px,6vw,88px)] leading-[1.05] tracking-[-0.02em]">
        Your symptoms have a cause.<br />
        We help you find it.
      </h1>
    </div>

    <!-- Subtitle -->
    <div class="text-left md:text-center max-w-[720px] md:mx-auto mb-16" data-animate data-delay="1">
      <p class="font-inter text-cream/50 text-lg leading-[1.5]">
        NimCore® combines comprehensive lab testing, specialist care, and<br class="hidden md:block" />
        personalized treatment to help you feel like yourself again.
      </p>
      <p class="font-inter text-teal text-lg leading-[1.5] font-medium mt-1">
        More energy, sharper focus, and real vitality.
      </p>
    </div>

    <!-- Dashboard Mockup in cream container -->
    <div class="relative rounded-2xl overflow-hidden" data-animate data-delay="2">
      <img
        src={dashboardImg.src}
        alt="NimCore Hormone Dashboard"
        class="w-full"
      />
      <span class="absolute top-4 right-4 bg-dark/60 backdrop-blur-sm text-teal font-inter text-xs font-medium px-3 py-1.5 rounded-full">
        New dashboard colors coming soon
      </span>
    </div>

    <!-- Stats Bar -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center sm:justify-center gap-4 sm:gap-16 mt-8" data-animate data-delay="3">
      <div class="flex items-center gap-3">
        <svg class="w-6 h-6 text-cream/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2C9 2 7 5 7 8c0 2 1 3.5 2.5 4.5L7 21l5-3 5 3-2.5-8.5C16 11.5 17 10 17 8c0-3-2-6-5-6z"/>
        </svg>
        <span class="font-inter text-cream/60 text-sm">70+ biomarkers</span>
      </div>
      <div class="flex items-center gap-3">
        <svg class="w-6 h-6 text-cream/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="font-inter text-cream/60 text-sm">Licensed physicians</span>
      </div>
      <div class="flex items-center gap-3">
        <svg class="w-6 h-6 text-cream/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="font-inter text-cream/60 text-sm">NABP-accredited pharmacy</span>
      </div>
    </div>
  </div>
</section>
