---
import img1 from '../assets/[7] Photography/iStock-1766905173.jpg';
import img2 from '../assets/[7] Photography/iStock-2203624688.jpg';
import img3 from '../assets/[7] Photography/iStock-1157992539.jpg';
import img4 from '../assets/[7] Photography/iStock-2210163746.jpg';

const cards = [
  {
    number: '01',
    image: img1.src,
    title: 'Clinician Prescribes',
    description: 'Provider writes the Rx in NovaMed. Platform shows pricing and compound options across pharmacy partners in real time.',
  },
  {
    number: '02',
    image: img2.src,
    title: 'Auto-Routed to Pharmacy',
    description: 'Prescription is sent digitally to the selected pharmacy. No faxes, no phone calls, no delays.',
  },
  {
    number: '03',
    image: img3.src,
    title: 'Track & Fulfill',
    description: 'Pharmacy compounds and ships. Clinic tracks status in real time. Patient gets automated shipping notifications.',
  },
  {
    number: '04',
    image: img4.src,
    title: 'Auto-Refill & Invoice',
    description: 'Refill cycles managed automatically. Invoicing reconciles in the background. Revenue flows without manual effort.',
  },
];
---

<section class="bg-[#1A1816] py-16 md:py-24 overflow-hidden" data-animate>
  <!-- Header -->
  <div id="providers-steps-header" class="max-w-[1200px] mx-auto px-5 md:px-[10px] mb-10 md:mb-16">
    <div class="flex items-end justify-between">
      <div>
        <p class="font-inter text-teal text-base mb-3 font-medium">How it works</p>
        <h2 class="font-fraunces text-cream text-[clamp(32px,5vw,72px)] leading-[1.05] tracking-[-0.02em]">
          Four automated steps.
        </h2>
      </div>
      <!-- Arrow Buttons -->
      <div class="flex items-center gap-2 pb-2">
        <button
          id="providers-steps-prev"
          class="w-10 h-10 rounded-full bg-cream/10 flex items-center justify-center text-cream/40 hover:text-cream hover:bg-cream/20 transition-colors cursor-pointer"
          aria-label="Previous slide"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          id="providers-steps-next"
          class="w-10 h-10 rounded-full bg-cream/10 flex items-center justify-center text-cream/40 hover:text-cream hover:bg-cream/20 transition-colors cursor-pointer"
          aria-label="Next slide"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Carousel -->
  <div class="relative overflow-hidden">
    <div id="providers-steps-track" class="flex gap-4 md:gap-6 transition-transform duration-500 ease-in-out">
      {cards.map(card => (
        <div class="providers-steps-slide shrink-0 w-[calc(100vw-40px)] md:w-[500px]">
          <div class="relative rounded-2xl h-[350px] md:h-[500px] overflow-hidden mb-4 md:mb-5">
            <img src={card.image} alt="" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-dark/20"></div>
            <span class="absolute bottom-4 left-4 md:bottom-6 md:left-6 font-fraunces text-[#f5f0ea] text-[70px] md:text-[100px] leading-none tracking-[-0.04em]">
              {card.number}
            </span>
          </div>
          <h3 class="font-inter text-cream text-base md:text-lg font-bold mb-2 px-1">{card.title}</h3>
          <p class="font-inter text-cream/40 text-sm leading-[1.6] px-1">{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function() {
    var track = document.getElementById('providers-steps-track');
    var header = document.getElementById('providers-steps-header');
    var prevBtn = document.getElementById('providers-steps-prev');
    var nextBtn = document.getElementById('providers-steps-next');
    var current = 0;
    var total = 4;

    function getSlideMetrics() {
      var slide = track.querySelector('.providers-steps-slide');
      if (!slide) return { cardWidth: 500, gap: 24 };
      var w = slide.getBoundingClientRect().width;
      var g = parseFloat(getComputedStyle(track).gap) || 24;
      return { cardWidth: w, gap: g };
    }

    function getLeftStart() {
      if (header) {
        var rect = header.getBoundingClientRect();
        var padding = parseFloat(getComputedStyle(header).paddingLeft);
        return rect.left + padding;
      }
      return 20;
    }

    function getOffset(index) {
      var m = getSlideMetrics();
      return -(index * (m.cardWidth + m.gap)) + getLeftStart();
    }

    function goTo(index) {
      if (index < 0) index = total - 1;
      if (index > total - 1) index = 0;
      current = index;
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
    }

    // Set initial position (no transition)
    track.style.transition = 'none';
    track.style.transform = 'translateX(' + getLeftStart() + 'px)';
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        track.style.transition = '';
      });
    });

    prevBtn?.addEventListener('click', function() { goTo(current - 1); });
    nextBtn?.addEventListener('click', function() { goTo(current + 1); });

    // Touch swipe
    var touchStartX = 0;
    var touchStartY = 0;
    var touchDeltaX = 0;
    var isSwiping = false;
    var swipeThreshold = 50;

    track.addEventListener('touchstart', function(e) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      touchDeltaX = 0;
      isSwiping = false;
      track.style.transition = 'none';
    }, { passive: true });

    track.addEventListener('touchmove', function(e) {
      var dx = e.touches[0].clientX - touchStartX;
      var dy = e.touches[0].clientY - touchStartY;
      if (!isSwiping && Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) {
        isSwiping = true;
      }
      if (isSwiping) {
        e.preventDefault();
        touchDeltaX = dx;
        track.style.transform = 'translateX(' + (getOffset(current) + touchDeltaX) + 'px)';
      }
    }, { passive: false });

    track.addEventListener('touchend', function() {
      track.style.transition = 'transform 0.5s ease-in-out';
      if (isSwiping) {
        if (touchDeltaX < -swipeThreshold) {
          goTo(current + 1);
        } else if (touchDeltaX > swipeThreshold) {
          goTo(current - 1);
        } else {
          track.style.transform = 'translateX(' + getOffset(current) + 'px)';
        }
      }
      isSwiping = false;
      touchDeltaX = 0;
    }, { passive: true });

    window.addEventListener('resize', function() {
      track.style.transition = 'none';
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          track.style.transition = '';
        });
      });
    });
  })();
</script>
