---
import img1 from '../assets/[7] Photography/iStock-2187968525.jpg';
import img2 from '../assets/[7] Photography/iStock-1276569663.jpg';
import img3 from '../assets/[7] Photography/iStock-2189538504.jpg';
import img4 from '../assets/[7] Photography/iStock-1317735408.jpg';
import img5 from '../assets/[7] Photography/iStock-1165116258.jpg';

const cards = [
  {
    image: img1.src,
    title: 'Enrollment vs. Forecast',
    description: 'Tracking participation against projected ranges',
  },
  {
    image: img2.src,
    title: 'Adherence & Persistence',
    description: 'Ongoing engagement at 90-day and 180-day milestones',
  },
  {
    image: img3.src,
    title: 'Nutrition Utilization',
    description: 'Meal program uptake as a secondary signal of engagement',
  },
  {
    image: img4.src,
    title: 'Cost Predictability',
    description: 'Actual spend vs. budgeted — no surprises',
  },
  {
    image: img5.src,
    title: 'Employee Experience',
    description: 'NPS and satisfaction scores from program participants',
  },
];
---

<section class="bg-cream py-16 md:py-24 overflow-hidden" data-animate>
  <!-- Header -->
  <div id="teams-success-header" class="max-w-[1200px] mx-auto px-5 md:px-[10px] mb-10 md:mb-16">
    <p class="font-inter text-dark/50 text-base mb-3">Measuring success</p>
    <h2 class="font-fraunces text-dark text-[clamp(32px,5vw,72px)] leading-[1.05] tracking-[-0.02em]">
      Participation, persistence,<br class="hidden md:block" />predictability
    </h2>
  </div>

  <!-- Carousel -->
  <div class="relative overflow-hidden">
    <div id="teams-success-track" class="flex gap-4 md:gap-6 transition-transform duration-500 ease-in-out">
      {cards.map((card) => (
        <div class="teams-success-slide shrink-0 w-[calc(100vw-40px)] md:w-[500px]">
          <div class="relative rounded-2xl h-[350px] md:h-[500px] overflow-hidden mb-4 md:mb-5">
            <img src={card.image} alt="" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-dark/10"></div>
          </div>
          <h3 class="font-inter text-dark text-base md:text-lg font-bold mb-2 px-1">{card.title}</h3>
          <p class="font-inter text-dark/50 text-sm leading-[1.6] px-1">{card.description}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Controls -->
  <div class="flex items-center justify-center gap-6 mt-8">
    <button
      id="teams-success-prev"
      class="flex items-center justify-center text-dark/40 hover:text-dark transition-colors cursor-pointer"
      aria-label="Previous slide"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M11 4L6 9l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Progress bar -->
    <div class="w-20 h-[2px] bg-dark/20 rounded-full overflow-hidden">
      <div id="teams-success-progress" class="h-full bg-teal rounded-full" style="width: 0%"></div>
    </div>

    <button
      id="teams-success-next"
      class="flex items-center justify-center text-dark/40 hover:text-dark transition-colors cursor-pointer"
      aria-label="Next slide"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</section>

<script is:inline>
  (function() {
    var track = document.getElementById('teams-success-track');
    var header = document.getElementById('teams-success-header');
    var prevBtn = document.getElementById('teams-success-prev');
    var nextBtn = document.getElementById('teams-success-next');
    var progress = document.getElementById('teams-success-progress');
    var current = 0;
    var total = 5;
    var DURATION = 4;

    function getSlideMetrics() {
      var slide = track.querySelector('.teams-success-slide');
      if (!slide) return { cardWidth: 500, gap: 24 };
      var w = slide.getBoundingClientRect().width;
      var g = parseFloat(getComputedStyle(track).gap) || 24;
      return { cardWidth: w, gap: g };
    }

    function getLeftStart() {
      if (header) {
        var rect = header.getBoundingClientRect();
        var padding = parseFloat(getComputedStyle(header).paddingLeft);
        return rect.left + padding;
      }
      return 20;
    }

    function getOffset(index) {
      var m = getSlideMetrics();
      return -(index * (m.cardWidth + m.gap)) + getLeftStart();
    }

    function startProgress() {
      if (!progress) return;
      progress.style.transition = 'none';
      progress.style.width = '0%';
      progress.getBoundingClientRect();
      progress.style.transition = 'width ' + DURATION + 's linear';
      progress.style.width = '100%';
    }

    function goTo(index) {
      if (index < 0) index = total - 1;
      if (index > total - 1) index = 0;
      current = index;
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
      startProgress();
    }

    progress.addEventListener('transitionend', function(e) {
      if (e.propertyName === 'width' && progress.style.width === '100%') {
        goTo(current + 1);
      }
    });

    track.style.transition = 'none';
    track.style.transform = 'translateX(' + getLeftStart() + 'px)';
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        track.style.transition = '';
      });
    });

    var section = track.closest('section');
    var hasStarted = false;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !hasStarted) {
          hasStarted = true;
          startProgress();
          observer.disconnect();
        }
      });
    }, { threshold: 0.4 });
    if (section) observer.observe(section);

    prevBtn?.addEventListener('click', function() { goTo(current - 1); });
    nextBtn?.addEventListener('click', function() { goTo(current + 1); });

    // Touch swipe
    var touchStartX = 0;
    var touchStartY = 0;
    var touchDeltaX = 0;
    var isSwiping = false;
    var swipeThreshold = 50;

    track.addEventListener('touchstart', function(e) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      touchDeltaX = 0;
      isSwiping = false;
      progress.style.transition = 'none';
      track.style.transition = 'none';
    }, { passive: true });

    track.addEventListener('touchmove', function(e) {
      var dx = e.touches[0].clientX - touchStartX;
      var dy = e.touches[0].clientY - touchStartY;
      if (!isSwiping && Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 10) {
        isSwiping = true;
      }
      if (isSwiping) {
        e.preventDefault();
        touchDeltaX = dx;
        track.style.transform = 'translateX(' + (getOffset(current) + touchDeltaX) + 'px)';
      }
    }, { passive: false });

    track.addEventListener('touchend', function() {
      track.style.transition = 'transform 0.5s ease-in-out';
      if (isSwiping) {
        if (touchDeltaX < -swipeThreshold) {
          goTo(current + 1);
        } else if (touchDeltaX > swipeThreshold) {
          goTo(current - 1);
        } else {
          track.style.transform = 'translateX(' + getOffset(current) + 'px)';
          startProgress();
        }
      }
      isSwiping = false;
      touchDeltaX = 0;
    }, { passive: true });

    window.addEventListener('resize', function() {
      track.style.transition = 'none';
      track.style.transform = 'translateX(' + getOffset(current) + 'px)';
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          track.style.transition = '';
        });
      });
    });
  })();
</script>
